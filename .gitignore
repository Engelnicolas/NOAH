*.pem
*.key
*.crt
*.cert
*.ca-bundle
*.p12
*.pfx
*.jks
*.keystore
*.truststore

# SSH keys
id_rsa*
id_ed25519*
id_ecdsa*
*.pub
known_hosts

# GPG keys
*.gpg
*.asc

