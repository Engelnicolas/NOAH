#!/bin/bash

# =======================
# NOAH - Main CLI Entry Point
# =======================
# Purpose: Single entry point for all NOAH operations

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT_VERSION="3.0.0"

# Color codes
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly RED='\033[0;31m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

show_help() {
    cat << 'EOF'
NOAH - Next Open-source Architecture Hub CLI

USAGE:
    ./noah COMMAND [OPTIONS]

COMMANDS:
    validate       Validate project (YAML, Ansible, Helm, scripts)
    fix            Fix common issues automatically
    infra          Infrastructure management (setup, deploy, status, teardown)
    monitoring     Monitoring stack management
    backup         Backup and restore operations
    help           Show this help message

EXAMPLES:
    ./noah validate --scope yaml       # Validate YAML files only
    ./noah fix --verbose              # Fix issues with verbose output
    ./noah infra status               # Check infrastructure status
    ./noah infra deploy --environment dev
    ./noah monitoring deploy          # Deploy monitoring stack

GLOBAL OPTIONS:
    -v, --verbose     Enable verbose output
    -h, --help       Show help message

For command-specific help, run:
    ./noah COMMAND --help

EOF
}

# Check if script exists and is executable
check_script() {
    local script_path="$1"
    if [ ! -f "$script_path" ]; then
        echo -e "${RED}Error: Script not found: $script_path${NC}" >&2
        return 1
    fi
    if [ ! -x "$script_path" ]; then
        echo -e "${YELLOW}Warning: Making script executable: $script_path${NC}"
        chmod +x "$script_path"
    fi
    return 0
}

# Main command routing
main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi

    local command="$1"
    shift

    case "$command" in
        "validate")
            script_path="${SCRIPT_DIR}/noah-validate"
            if check_script "$script_path"; then
                exec "$script_path" "$@"
            fi
            ;;
        "fix")
            script_path="${SCRIPT_DIR}/noah-fix.py"
            if check_script "$script_path"; then
                exec python3 "$script_path" "$@"
            fi
            ;;
        "infra")
            script_path="${SCRIPT_DIR}/noah-infra"
            if check_script "$script_path"; then
                exec "$script_path" "$@"
            fi
            ;;
        "monitoring")
            script_path="${SCRIPT_DIR}/noah-monitoring.py"
            if check_script "$script_path"; then
                exec python3 "$script_path" "$@"
            fi
            ;;
        "backup")
            echo -e "${YELLOW}Backup functionality will be implemented in future versions${NC}"
            echo -e "${YELLOW}For now, use Kubernetes native backup tools or Helm commands${NC}"
            exit 0
            ;;
        "help"|"-h"|"--help")
            show_help
            ;;
        "version"|"-v"|"--version")
            echo "NOAH CLI v${SCRIPT_VERSION}"
            ;;
        *)
            echo -e "${RED}Error: Unknown command: $command${NC}" >&2
            echo ""
            show_help
            exit 1
            ;;
    esac
}

main "$@"
