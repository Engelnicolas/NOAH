#!/bin/bash

# =======================
# NOAH - Unified Infrastructure Management Script
# =======================
# Combines: setup_infra.sh, deploy_and_verify_helm.sh, status_check.sh
# Purpose: Single script for infrastructure deployment and management

set -euo pipefail

# Script metadata
SCRIPT_VERSION="3.3.0"  # Updated: Enhanced network error handling, offline mode detection, improved diagnostics
SCRIPT_NAME="noah-infra"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Configuration
NAMESPACE_PREFIX="noah"
HELM_TIMEOUT="600s"
VERBOSE=false
DRY_RUN=false
AUTO_INSTALL=true  # New: Automatically install missing prerequisites
SKIP_K8S_CHECK=false  # New: Skip Kubernetes connectivity check
ACTION="status"  # setup, deploy, status, teardown
USE_SIMPLIFIED_CHARTS=true  # New: Use simplified chart structure
VALUES_DIR="../Helm/values"  # Values directory

# Color codes
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Logging functions
log() {
    echo -e "${GREEN}[INFO]${NC} $(date '+%H:%M:%S') - $1"
}

log_warn() {
    echo -e "${YELLOW}[WARN]${NC} $(date '+%H:%M:%S') - $1"
}

log_error() {
    echo -e "${RED}[ERROR]${NC} $(date '+%H:%M:%S') - $1" >&2
}

log_debug() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "${BLUE}[DEBUG]${NC} $(date '+%H:%M:%S') - $1"
    fi
}

# Help function
show_help() {
    cat << 'EOF'
NOAH Unified Infrastructure Management Script

USAGE:
    ./noah-infra ACTION [OPTIONS]

ACTIONS:
    setup           Set up infrastructure prerequisites
    deploy          Deploy Helm charts
    status          Check infrastructure status
    teardown        Remove deployed infrastructure

PREREQUISITES:
    The script will automatically install missing tools:
    - kubectl       Kubernetes command-line tool
    - helm          Kubernetes package manager
    - ansible       Configuration management tool
    - minikube      Local Kubernetes cluster
    - docker        Container runtime

OPTIONS:
    -n, --namespace PREFIX   Namespace prefix (default: noah)
    -t, --timeout TIMEOUT    Helm timeout (default: 600s)
    -v, --verbose           Enable verbose output
    --dry-run              Show what would be done without executing
    --no-auto-install      Disable automatic installation of missing tools
    --skip-k8s-check       Skip Kubernetes connectivity check (for testing)
    -h, --help             Show this help message

EXAMPLES:
    ./noah-infra status                    # Check current status
    ./noah-infra setup                     # Set up infrastructure
    ./noah-infra deploy --verbose          # Deploy with verbose output
    ./noah-infra teardown --dry-run        # Show what would be removed
    ./noah-infra setup --no-auto-install   # Check prerequisites without auto-install

KUBERNETES SETUP:
    The script will automatically start a minikube cluster if no Kubernetes
    cluster is accessible. This provides a local development environment.

TROUBLESHOOTING NETWORK ISSUES:
    If you see "net::ERR_NAME_NOT_RESOLVED" or similar network errors:
    
    1. Check DNS settings:
       - Try using public DNS: 8.8.8.8 or 1.1.1.1
       - On Ubuntu: sudo systemctl restart systemd-resolved
    
    2. Check internet connectivity:
       - Test: ping google.com
       - Test: curl -I https://github.com
    
    3. Corporate networks:
       - Configure HTTP_PROXY and HTTPS_PROXY environment variables
       - Check with your IT department about firewall rules
    
    4. Alternative installation:
       - Use --no-auto-install flag and install tools manually
       - Use package managers: apt, yum, dnf, snap
       - Download tools directly from official websites

OFFLINE/MANUAL INSTALLATION:
    If automatic installation fails, install tools manually:
    - kubectl: https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/
    - helm: https://helm.sh/docs/intro/install/
    - ansible: pip3 install --user ansible
    - minikube: https://minikube.sigs.k8s.io/docs/start/
    - docker: https://docs.docker.com/engine/install/

EOF
}

# Network-aware download function with retry and timeout
download_with_retry() {
    local url="$1"
    local output="$2"
    local max_attempts=3
    local timeout=30
    
    for attempt in $(seq 1 $max_attempts); do
        log_debug "Download attempt $attempt/$max_attempts for $url"
        if curl -fsSL --connect-timeout 10 --max-time $timeout "$url" -o "$output" 2>/dev/null; then
            return 0
        fi
        log_warn "Download attempt $attempt failed, retrying..."
        sleep 2
    done
    
    log_error "Failed to download $url after $max_attempts attempts"
    return 1
}

# Check if we can install via package manager (preferred for network issues)
try_package_manager_install() {
    local tool="$1"
    
    case "$tool" in
        "kubectl")
            if command -v apt-get >/dev/null 2>&1; then
                log "Trying kubectl via apt-get..."
                return 1  # Skip for now, requires complex setup
            elif command -v yum >/dev/null 2>&1; then
                log "Trying kubectl via yum..."
                if sudo yum install -y kubectl >/dev/null 2>&1; then
                    return 0
                fi
            elif command -v snap >/dev/null 2>&1; then
                log "Trying kubectl via snap..."
                if sudo snap install kubectl --classic >/dev/null 2>&1; then
                    return 0
                fi
            fi
            ;;
        "helm")
            if command -v snap >/dev/null 2>&1; then
                log "Trying Helm via snap..."
                if sudo snap install helm --classic >/dev/null 2>&1; then
                    return 0
                fi
            fi
            ;;
        "docker")
            # Docker installation via package manager is already handled
            return 1
            ;;
        "minikube")
            if command -v snap >/dev/null 2>&1; then
                log "Trying minikube via snap..."
                if sudo snap install minikube >/dev/null 2>&1; then
                    return 0
                fi
            fi
            ;;
    esac
    
    return 1
}

# Install missing tools automatically
# Check network connectivity with detailed diagnostics
check_network_connectivity() {
    local test_urls=("https://www.google.com" "https://github.com" "https://kubernetes.io")
    local timeout=10
    local success=false
    
    log_debug "Checking network connectivity..."
    
    # First check if curl is available
    if ! command -v curl >/dev/null 2>&1; then
        log_warn "curl not available for network connectivity check"
        return 0  # Assume network is OK if we can't check
    fi
    
    # Test connectivity to multiple endpoints
    for url in "${test_urls[@]}"; do
        if curl -s --connect-timeout 5 --max-time $timeout "$url" >/dev/null 2>&1; then
            log_debug "Successfully connected to $url"
            success=true
            break
        else
            log_debug "Failed to connect to $url"
        fi
    done
    
    if [ "$success" = true ]; then
        return 0
    fi
    
    # Additional diagnostics
    log_debug "Running network diagnostics..."
    
    # Check DNS resolution
    if command -v nslookup >/dev/null 2>&1; then
        if ! nslookup google.com >/dev/null 2>&1; then
            log_debug "DNS resolution failed - this could be the cause of net::ERR_NAME_NOT_RESOLVED"
        fi
    fi
    
    # Check basic connectivity
    if command -v ping >/dev/null 2>&1; then
        if ! ping -c 1 -W 5 8.8.8.8 >/dev/null 2>&1; then
            log_debug "Cannot reach 8.8.8.8 - network connectivity issue"
        fi
    fi
    
    return 1
}

# Detect if we're in an offline environment
is_offline_environment() {
    # Check for common indicators of offline/restricted environments
    if [[ -n "${NO_INTERNET:-}" ]] || [[ -n "${OFFLINE_MODE:-}" ]]; then
        return 0
    fi
    
    # Check if we're in a restricted environment by testing multiple endpoints quickly
    if ! check_network_connectivity >/dev/null 2>&1; then
        return 0
    fi
    
    return 1
}

install_tool() {
    local tool="$1"
    
    log "Installing $tool..."
    
    if [ "$DRY_RUN" = true ]; then
        log "DRY RUN: Would install $tool"
        return 0
    fi
    
    # Check network connectivity before attempting downloads
    if ! check_network_connectivity; then
        log_error "Network connectivity issue detected"
        log "This can be caused by:"
        log "  - No internet connection"
        log "  - DNS resolution issues (net::ERR_NAME_NOT_RESOLVED)"
        log "  - Firewall blocking outbound connections"
        log "  - Corporate proxy settings"
        log ""
        log "Solutions:"
        log "  - Check your internet connection"
        log "  - Try a different DNS server (e.g., 8.8.8.8)"
        log "  - Configure proxy settings if behind corporate firewall"
        log "  - Install $tool manually or use --no-auto-install flag"
        log ""
        log "Manual installation guides:"
        case "$tool" in
            "kubectl") log "  kubectl: https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/" ;;
            "helm") log "  helm: https://helm.sh/docs/intro/install/" ;;
            "ansible") log "  ansible: pip3 install --user ansible" ;;
            "minikube") log "  minikube: https://minikube.sigs.k8s.io/docs/start/" ;;
            "docker") log "  docker: https://docs.docker.com/engine/install/" ;;
        esac
        return 1
    fi
    
    # Ensure curl is available for downloads (except for tools that use package managers)
    if ! command -v curl >/dev/null 2>&1 && [ "$tool" != "ansible" ] && [ "$tool" != "docker" ]; then
        log_error "curl is required to install $tool but is not available"
        log "Please install curl first: sudo apt-get install curl (Ubuntu/Debian) or sudo yum install curl (RHEL/CentOS)"
        return 1
    fi
    
    case "$tool" in
        "kubectl")
            log "Installing kubectl..."
            
            # Try package manager first
            if try_package_manager_install "kubectl"; then
                log "✅ kubectl installed successfully via package manager"
                return 0
            fi
            
            # Manual installation as fallback
            local kubectl_version
            if ! kubectl_version=$(curl -L -s --connect-timeout 10 --max-time 30 https://dl.k8s.io/release/stable.txt 2>/dev/null); then
                log_error "Failed to get kubectl version - network connectivity issue"
                log "Please check your internet connection or install kubectl manually"
                log "Manual installation: https://kubernetes.io/docs/tasks/tools/install-kubectl-linux/"
                return 1
            fi
            
            if download_with_retry "https://dl.k8s.io/release/${kubectl_version}/bin/linux/amd64/kubectl" "kubectl"; then
                chmod +x kubectl
                if [ -w /usr/local/bin ]; then
                    mv kubectl /usr/local/bin/
                else
                    sudo mv kubectl /usr/local/bin/ || {
                        log_error "Failed to move kubectl to /usr/local/bin/"
                        return 1
                    }
                fi
                log "✅ kubectl installed successfully"
            else
                log_error "Failed to download kubectl due to network issues"
                return 1
            fi
            ;;
        "helm")
            log "Installing Helm..."
            
            # Try package manager first
            if try_package_manager_install "helm"; then
                log "✅ Helm installed successfully via package manager"
                return 0
            fi
            
            # Manual installation as fallback
            if download_with_retry "https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3" "get-helm-3.sh"; then
                chmod +x get-helm-3.sh
                if timeout 120 ./get-helm-3.sh >/dev/null 2>&1; then
                    rm -f get-helm-3.sh
                    log "✅ Helm installed successfully"
                else
                    rm -f get-helm-3.sh
                    log_error "Helm installation script failed"
                    return 1
                fi
            else
                log_error "Failed to download Helm installation script due to network issues"
                return 1
            fi
            ;;
        "ansible")
            log "Installing Ansible..."
            if command -v pip3 >/dev/null 2>&1; then
                if pip3 install --user ansible; then
                    log "✅ Ansible installed successfully via pip3"
                    log "Note: You may need to add ~/.local/bin to your PATH"
                else
                    log_error "Failed to install Ansible via pip3"
                    return 1
                fi
            elif command -v pip >/dev/null 2>&1; then
                if pip install --user ansible; then
                    log "✅ Ansible installed successfully via pip"
                    log "Note: You may need to add ~/.local/bin to your PATH"
                else
                    log_error "Failed to install Ansible via pip"
                    return 1
                fi
            elif command -v apt-get >/dev/null 2>&1; then
                # Ubuntu/Debian
                if sudo apt-get update && sudo apt-get install -y ansible; then
                    log "✅ Ansible installed successfully via apt-get"
                else
                    log_error "Failed to install Ansible via apt-get"
                    return 1
                fi
            elif command -v yum >/dev/null 2>&1; then
                # RHEL/CentOS
                if sudo yum install -y ansible; then
                    log "✅ Ansible installed successfully via yum"
                else
                    log_error "Failed to install Ansible via yum"
                    return 1
                fi
            elif command -v dnf >/dev/null 2>&1; then
                # Fedora
                if sudo dnf install -y ansible; then
                    log "✅ Ansible installed successfully via dnf"
                else
                    log_error "Failed to install Ansible via dnf"
                    return 1
                fi
            else
                log_error "No suitable package manager found to install Ansible"
                log "Available options: pip3, pip, apt-get, yum, dnf"
                log "Please install one of these package managers first"
                return 1
            fi
            ;;
        "minikube")
            log "Installing minikube..."
            
            # Try package manager first
            if try_package_manager_install "minikube"; then
                log "✅ minikube installed successfully via package manager"
                return 0
            fi
            
            # Manual installation as fallback
            if download_with_retry "https://storage.googleapis.com/minikube/releases/latest/minikube-linux-amd64" "minikube-linux-amd64"; then
                chmod +x minikube-linux-amd64
                if [ -w /usr/local/bin ]; then
                    mv minikube-linux-amd64 /usr/local/bin/minikube
                else
                    sudo mv minikube-linux-amd64 /usr/local/bin/minikube || {
                        log_error "Failed to move minikube to /usr/local/bin/"
                        return 1
                    }
                fi
                log "✅ minikube installed successfully"
            else
                log_error "Failed to download minikube due to network issues"
                log "Please check your internet connection or install minikube manually"
                log "Manual installation: https://minikube.sigs.k8s.io/docs/start/"
                return 1
            fi
            ;;
        "docker")
            log "Installing Docker..."
            # Install Docker using official repository method
            if command -v apt-get >/dev/null 2>&1; then
                # Ubuntu/Debian
                log "Setting up Docker repository for Ubuntu/Debian..."
                if ! (sudo apt-get update && \
                      sudo apt-get install -y ca-certificates curl gnupg lsb-release && \
                      sudo mkdir -p /etc/apt/keyrings && \
                      curl -fsSL --connect-timeout 10 --max-time 30 https://download.docker.com/linux/ubuntu/gpg | sudo gpg --dearmor -o /etc/apt/keyrings/docker.gpg && \
                      echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $(lsb_release -cs) stable" | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null && \
                      sudo apt-get update && \
                      sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin); then
                    log_error "Failed to install Docker via apt-get - this could be due to network issues"
                    log "Manual installation guide: https://docs.docker.com/engine/install/ubuntu/"
                    return 1
                fi
                log "✅ Docker installed successfully via apt-get"
                log "Note: You may need to add your user to the docker group: sudo usermod -aG docker \$USER"
            elif command -v yum >/dev/null 2>&1; then
                # RHEL/CentOS
                log "Setting up Docker repository for RHEL/CentOS..."
                if ! (sudo yum install -y yum-utils && \
                      sudo yum-config-manager --add-repo https://download.docker.com/linux/centos/docker-ce.repo && \
                      sudo yum install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin); then
                    log_error "Failed to install Docker via yum - this could be due to network issues"
                    log "Manual installation guide: https://docs.docker.com/engine/install/centos/"
                    return 1
                fi
                log "✅ Docker installed successfully via yum"
                log "Note: You may need to add your user to the docker group: sudo usermod -aG docker \$USER"
            elif command -v dnf >/dev/null 2>&1; then
                # Fedora
                log "Setting up Docker repository for Fedora..."
                if ! (sudo dnf -y install dnf-plugins-core && \
                      sudo dnf config-manager --add-repo https://download.docker.com/linux/fedora/docker-ce.repo && \
                      sudo dnf install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin); then
                    log_error "Failed to install Docker via dnf - this could be due to network issues"
                    log "Manual installation guide: https://docs.docker.com/engine/install/fedora/"
                    return 1
                fi
                log "✅ Docker installed successfully via dnf"
                log "Note: You may need to add your user to the docker group: sudo usermod -aG docker \$USER"
            else
                log_error "No suitable package manager found to install Docker"
                log "Available options: apt-get (Ubuntu/Debian), yum (RHEL/CentOS), dnf (Fedora)"
                log "Please install Docker manually from https://docs.docker.com/engine/install/"
                return 1
            fi
            ;;
        *)
            log_error "Unknown tool: $tool"
            return 1
            ;;
    esac
}

# Check prerequisites
check_prerequisites() {
    log "Checking prerequisites..."
    
    local missing_tools=()
    local install_failed=()
    
    # Check required tools
    command -v kubectl >/dev/null 2>&1 || missing_tools+=("kubectl")
    command -v helm >/dev/null 2>&1 || missing_tools+=("helm")
    command -v ansible >/dev/null 2>&1 || missing_tools+=("ansible")
    command -v minikube >/dev/null 2>&1 || missing_tools+=("minikube")
    command -v docker >/dev/null 2>&1 || missing_tools+=("docker")
    
    # Install missing tools automatically
    if [ ${#missing_tools[@]} -gt 0 ]; then
        log_warn "Missing required tools: ${missing_tools[*]}"
        
        if [ "$AUTO_INSTALL" = false ]; then
            log_error "Automatic installation is disabled"
            if is_offline_environment; then
                log "🔧 Offline environment detected. Manual installation required:"
                for tool in "${missing_tools[@]}"; do
                    case "$tool" in
                        "kubectl") log "  - kubectl: Use your package manager or download from https://kubernetes.io/docs/tasks/tools/" ;;
                        "helm") log "  - helm: Use 'snap install helm --classic' or download from https://helm.sh/" ;;
                        "ansible") log "  - ansible: Use 'pip3 install --user ansible' or your package manager" ;;
                        "minikube") log "  - minikube: Use 'snap install minikube' or download from GitHub releases" ;;
                        "docker") log "  - docker: Use your package manager or install from repositories" ;;
                    esac
                done
            else
                log "Please install missing tools manually and try again"
            fi
            return 1
        fi
        
        # Check if we're in offline mode
        if is_offline_environment; then
            log_warn "🌐 Network connectivity issues detected"
            log "Trying package manager installations first (offline-friendly)..."
            
            # In offline mode, try package managers first for all tools
            local pm_success=()
            for tool in "${missing_tools[@]}"; do
                if try_package_manager_install "$tool"; then
                    pm_success+=("$tool")
                    log "✅ $tool installed via package manager"
                fi
            done
            
            # Remove successfully installed tools from missing list
            for tool in "${pm_success[@]}"; do
                missing_tools=("${missing_tools[@]/$tool}")
            done
            missing_tools=("${missing_tools[@]}")  # Remove empty elements
            
            if [ ${#missing_tools[@]} -gt 0 ]; then
                log_error "❌ Could not install via package manager: ${missing_tools[*]}"
                log "Manual installation required in offline environment"
                log "Use --no-auto-install flag to see manual installation instructions"
                return 1
            fi
        else
            log "Attempting to install missing tools automatically..."
            
            for tool in "${missing_tools[@]}"; do
                if ! install_tool "$tool"; then
                    install_failed+=("$tool")
                fi
            done
        fi
        
        if [ ${#install_failed[@]} -gt 0 ]; then
            log_error "Failed to install tools: ${install_failed[*]}"
            log "Please install these tools manually and try again"
            return 1
        fi
        
        log "✅ All missing tools have been installed"
        
        # Re-check that tools are now available
        local still_missing=()
        command -v kubectl >/dev/null 2>&1 || still_missing+=("kubectl")
        command -v helm >/dev/null 2>&1 || still_missing+=("helm")
        command -v ansible >/dev/null 2>&1 || still_missing+=("ansible")
        command -v minikube >/dev/null 2>&1 || still_missing+=("minikube")
        command -v docker >/dev/null 2>&1 || still_missing+=("docker")
        
        if [ ${#still_missing[@]} -gt 0 ]; then
            log_error "Tools still not available after installation: ${still_missing[*]}"
            log "You may need to restart your shell or update your PATH"
            log "For Docker, you may also need to log out and back in after adding to docker group"
            return 1
        fi
    fi
    
    # Check Kubernetes connectivity
    if [ "$SKIP_K8S_CHECK" = false ]; then
        if ! kubectl cluster-info >/dev/null 2>&1; then
            log_warn "Kubernetes cluster not accessible"
            
            # Try to start minikube if available
            if command -v minikube >/dev/null 2>&1; then
                log "Attempting to start minikube cluster..."
                if [ "$DRY_RUN" = true ]; then
                    log "DRY RUN: Would start minikube cluster"
                else
                    # Check if minikube cluster exists
                    if minikube status >/dev/null 2>&1; then
                        log "Starting existing minikube cluster..."
                        minikube start
                    else
                        log "Creating and starting new minikube cluster..."
                        # Check if Docker is running (for Docker driver)
                        if command -v docker >/dev/null 2>&1 && docker info >/dev/null 2>&1; then
                            minikube start --driver=docker
                        else
                            log_warn "Docker not available or not running, trying with auto-detect driver"
                            minikube start
                        fi
                    fi
                    
                    # Re-check Kubernetes connectivity
                    if kubectl cluster-info >/dev/null 2>&1; then
                        log "✅ minikube cluster started successfully"
                    else
                        log_error "Failed to start minikube cluster"
                        log "Use --skip-k8s-check to bypass this check for testing"
                        return 1
                    fi
                fi
            else
                log "Make sure kubectl is configured and cluster is running"
                log "Use --skip-k8s-check to bypass this check for testing"
                return 1
            fi
        else
            log "✅ Kubernetes cluster is accessible"
        fi
    else
        log_warn "Skipping Kubernetes connectivity check"
    fi
    
    log "Prerequisites check passed"
    return 0
}

# Setup infrastructure
setup_infrastructure() {
    log "Setting up infrastructure"
    
    if [ "$DRY_RUN" = true ]; then
        log "DRY RUN: Would set up infrastructure"
        return 0
    fi
    
    # Create namespace if it doesn't exist
    local namespace="${NAMESPACE_PREFIX}"
    if ! kubectl get namespace "$namespace" >/dev/null 2>&1; then
        log "Creating namespace: $namespace"
        kubectl create namespace "$namespace"
    else
        log "Namespace already exists: $namespace"
    fi
    
    # Run Ansible setup if playbook exists
    if [ -f "Ansible/main.yml" ]; then
        log "Running Ansible setup playbook..."
        cd Ansible
        ansible-playbook main.yml -i inventory || {
            log_error "Ansible playbook failed"
            cd ..
            return 1
        }
        cd ..
    fi
    
    log "Infrastructure setup completed"
}

# Deploy Helm charts
deploy_charts() {
    log "Deploying Helm charts"
    
    local namespace="${NAMESPACE_PREFIX}"
    local deployed=0
    local failed=0
    
    # Change to the parent directory to access Helm charts
    local helm_base_dir="${SCRIPT_DIR}/../Helm"
    
    for chart_dir in "${helm_base_dir}"/*/; do
        if [ -f "${chart_dir}Chart.yaml" ]; then
            local chart_name=$(basename "$chart_dir")
            local release_name="${chart_name}"
            
            log "Deploying chart: $chart_name"
            
            if [ "$DRY_RUN" = true ]; then
                log "DRY RUN: Would deploy $chart_name"
                continue
            fi
            
            if [ "$USE_SIMPLIFIED_CHARTS" = true ]; then
                # Use simplified chart structure with default values
                local values_file="${SCRIPT_DIR}/${VALUES_DIR}/values-minimal.yaml"
                
                if [ -f "$values_file" ]; then
                    log "Using values file: $values_file"
                    helm upgrade --install "$release_name" "$chart_dir" \
                        --namespace "$namespace" \
                        --timeout "$HELM_TIMEOUT" \
                        --wait \
                        -f "$values_file" >/dev/null 2>&1 && {
                        log "✅ Successfully deployed: $chart_name"
                        ((deployed++))
                        continue
                    }
                else
                    log_error "❌ Values file not found: $values_file"
                    ((failed++))
                    continue
                fi
            fi
            
            # Update dependencies if Chart.lock exists
            if [ -f "${chart_dir}Chart.lock" ]; then
                log_debug "Updating dependencies for $chart_name"
                helm dependency update "$chart_dir" >/dev/null 2>&1 || true
            fi
            
            # Deploy chart
            if helm upgrade --install "$release_name" "$chart_dir" \
                --namespace "$namespace" \
                --timeout "$HELM_TIMEOUT" \
                --wait >/dev/null 2>&1; then
                log "✅ Successfully deployed: $chart_name"
                ((deployed++))
            else
                log_error "❌ Failed to deploy: $chart_name"
                ((failed++))
            fi
        fi
    done
    
    log "Deployment summary: $deployed successful, $failed failed"
    return $failed
}

# Check infrastructure status
check_status() {
    log "Checking infrastructure status"
    
    local namespace="${NAMESPACE_PREFIX}"
    
    # Check if namespace exists
    if ! kubectl get namespace "$namespace" >/dev/null 2>&1; then
        log_warn "Namespace does not exist: $namespace"
        return 1
    fi
    
    echo ""
    echo "📊 Infrastructure Status"
    echo "======================="
    echo "Namespace: $namespace"
    echo ""
    
    # Helm releases
    echo "🚀 Helm Releases:"
    if command -v helm >/dev/null 2>&1; then
        helm list -n "$namespace" 2>/dev/null || echo "No Helm releases found"
    else
        echo "Helm not available"
    fi
    echo ""
    
    # Pods status
    echo "📦 Pods:"
    kubectl get pods -n "$namespace" 2>/dev/null || echo "No pods found"
    echo ""
    
    # Services
    echo "🌐 Services:"
    kubectl get services -n "$namespace" 2>/dev/null || echo "No services found"
    echo ""
    
    # Ingresses
    echo "🔗 Ingresses:"
    kubectl get ingress -n "$namespace" 2>/dev/null || echo "No ingresses found"
    echo ""
    
    # Check for failed pods
    local failed_pods=$(kubectl get pods -n "$namespace" --field-selector=status.phase=Failed -o name 2>/dev/null | wc -l)
    local pending_pods=$(kubectl get pods -n "$namespace" --field-selector=status.phase=Pending -o name 2>/dev/null | wc -l)
    
    if [ "$failed_pods" -gt 0 ]; then
        log_warn "$failed_pods pods in Failed state"
    fi
    
    if [ "$pending_pods" -gt 0 ]; then
        log_warn "$pending_pods pods in Pending state"
    fi
    
    if [ "$failed_pods" -eq 0 ] && [ "$pending_pods" -eq 0 ]; then
        log "✅ All pods appear healthy"
    fi
}

# Teardown infrastructure
teardown_infrastructure() {
    log "Tearing down infrastructure"
    
    local namespace="${NAMESPACE_PREFIX}"
    
    if [ "$DRY_RUN" = true ]; then
        log "DRY RUN: Would teardown infrastructure in namespace: $namespace"
        return 0
    fi
    
    # Uninstall Helm releases
    if command -v helm >/dev/null 2>&1; then
        local releases=$(helm list -n "$namespace" -q 2>/dev/null || true)
        if [ -n "$releases" ]; then
            log "Uninstalling Helm releases..."
            echo "$releases" | while read -r release; do
                if [ -n "$release" ]; then
                    log "Uninstalling release: $release"
                    helm uninstall "$release" -n "$namespace" >/dev/null 2>&1 || true
                fi
            done
        fi
    fi
    
    # Delete namespace
    if kubectl get namespace "$namespace" >/dev/null 2>&1; then
        log "Deleting namespace: $namespace"
        kubectl delete namespace "$namespace" --timeout=60s >/dev/null 2>&1 || {
            log_warn "Namespace deletion may be stuck, consider manual cleanup"
        }
    fi
    
    log "Infrastructure teardown completed"
}

# Main execution logic
main() {
    case "$ACTION" in
        "setup")
            check_prerequisites || exit 1
            setup_infrastructure || exit 1
            ;;
        "deploy")
            check_prerequisites || exit 1
            deploy_charts || exit 1
            ;;
        "status")
            check_status
            ;;
        "teardown")
            teardown_infrastructure
            ;;
        *)
            log_error "Invalid action: $ACTION"
            show_help
            exit 1
            ;;
    esac
}

# Parse command line arguments
if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

ACTION="$1"
shift

while [[ $# -gt 0 ]]; do
    case $1 in
        -n|--namespace)
            NAMESPACE_PREFIX="$2"
            shift 2
            ;;
        -t|--timeout)
            HELM_TIMEOUT="$2"
            shift 2
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --no-auto-install)
            AUTO_INSTALL=false
            shift
            ;;
        --skip-k8s-check)
            SKIP_K8S_CHECK=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# Execute main function
main
