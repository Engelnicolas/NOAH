#!/bin/bash

# =======================
# NOAH - Log Viewer Utility
# =======================
# Purpose: View and analyze NOAH deployment logs

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
LOG_DIR="${SCRIPT_DIR}/logs"
ERROR_LOG_DIR="${LOG_DIR}/errors"
DEPLOYMENT_LOG_DIR="${LOG_DIR}/deployments"

# Color codes
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

show_help() {
    cat << 'EOF'
NOAH Log Viewer

USAGE:
    ./noah-logs COMMAND [OPTIONS]

COMMANDS:
    errors              Show recent error logs
    deployments        Show recent deployment logs
    latest             Show latest deployment log
    tail               Follow latest deployment log
    clean              Clean old logs (keeps last 10)
    summary            Show log summary

EXAMPLES:
    ./noah-logs errors              # List all error logs
    ./noah-logs deployments         # List all deployment logs
    ./noah-logs latest              # Show latest deployment
    ./noah-logs tail                # Follow latest deployment
    ./noah-logs clean               # Clean old logs

EOF
}

list_errors() {
    echo -e "${RED}=== ERROR LOGS ===${NC}"
    if [[ -d "$ERROR_LOG_DIR" ]]; then
        if ls "$ERROR_LOG_DIR"/*.log >/dev/null 2>&1; then
            ls -la "$ERROR_LOG_DIR"/*.log | while read -r line; do
                echo -e "${YELLOW}$line${NC}"
            done
            echo ""
            echo -e "${BLUE}To view an error log: cat $ERROR_LOG_DIR/FILENAME${NC}"
        else
            echo "No error logs found"
        fi
    else
        echo "Error log directory does not exist"
    fi
}

list_deployments() {
    echo -e "${GREEN}=== DEPLOYMENT LOGS ===${NC}"
    if [[ -d "$DEPLOYMENT_LOG_DIR" ]]; then
        if ls "$DEPLOYMENT_LOG_DIR"/*.log >/dev/null 2>&1; then
            ls -la "$DEPLOYMENT_LOG_DIR"/*.log | while read -r line; do
                echo -e "${BLUE}$line${NC}"
            done
            echo ""
            echo -e "${BLUE}To view a deployment log: cat $DEPLOYMENT_LOG_DIR/FILENAME${NC}"
        else
            echo "No deployment logs found"
        fi
    else
        echo "Deployment log directory does not exist"
    fi
}

show_latest() {
    echo -e "${GREEN}=== LATEST DEPLOYMENT LOG ===${NC}"
    if [[ -d "$DEPLOYMENT_LOG_DIR" ]]; then
        local latest_log=$(ls -t "$DEPLOYMENT_LOG_DIR"/*.log 2>/dev/null | head -n1)
        if [[ -n "$latest_log" ]]; then
            echo -e "${BLUE}File: $latest_log${NC}"
            echo ""
            cat "$latest_log"
        else
            echo "No deployment logs found"
        fi
    else
        echo "Deployment log directory does not exist"
    fi
}

tail_latest() {
    echo -e "${GREEN}=== FOLLOWING LATEST DEPLOYMENT LOG ===${NC}"
    if [[ -d "$DEPLOYMENT_LOG_DIR" ]]; then
        local latest_log=$(ls -t "$DEPLOYMENT_LOG_DIR"/*.log 2>/dev/null | head -n1)
        if [[ -n "$latest_log" ]]; then
            echo -e "${BLUE}Following: $latest_log${NC}"
            echo -e "${YELLOW}Press Ctrl+C to stop${NC}"
            echo ""
            tail -f "$latest_log"
        else
            echo "No deployment logs found"
        fi
    else
        echo "Deployment log directory does not exist"
    fi
}

clean_logs() {
    echo -e "${YELLOW}=== CLEANING OLD LOGS ===${NC}"
    
    # Keep last 10 deployment logs
    if [[ -d "$DEPLOYMENT_LOG_DIR" ]]; then
        local count=$(ls "$DEPLOYMENT_LOG_DIR"/*.log 2>/dev/null | wc -l || echo 0)
        if [[ $count -gt 10 ]]; then
            echo "Found $count deployment logs, keeping latest 10..."
            ls -t "$DEPLOYMENT_LOG_DIR"/*.log | tail -n +11 | while read -r file; do
                echo "Removing: $file"
                rm -f "$file"
            done
        else
            echo "Only $count deployment logs found, no cleanup needed"
        fi
    fi
    
    # Keep last 20 error logs
    if [[ -d "$ERROR_LOG_DIR" ]]; then
        local count=$(ls "$ERROR_LOG_DIR"/*.log 2>/dev/null | wc -l || echo 0)
        if [[ $count -gt 20 ]]; then
            echo "Found $count error logs, keeping latest 20..."
            ls -t "$ERROR_LOG_DIR"/*.log | tail -n +21 | while read -r file; do
                echo "Removing: $file"
                rm -f "$file"
            done
        else
            echo "Only $count error logs found, no cleanup needed"
        fi
    fi
    
    echo -e "${GREEN}Log cleanup completed${NC}"
}

show_summary() {
    echo -e "${BLUE}=== LOG SUMMARY ===${NC}"
    echo ""
    
    if [[ -d "$LOG_DIR" ]]; then
        echo -e "${GREEN}Log Directory:${NC} $LOG_DIR"
        echo ""
        
        if [[ -d "$DEPLOYMENT_LOG_DIR" ]]; then
            local deploy_count=$(ls "$DEPLOYMENT_LOG_DIR"/*.log 2>/dev/null | wc -l)
            deploy_count=${deploy_count:-0}
            echo -e "${GREEN}Deployment Logs:${NC} $deploy_count files"
            if [[ $deploy_count -gt 0 ]]; then
                local latest_deploy=$(ls -t "$DEPLOYMENT_LOG_DIR"/*.log 2>/dev/null | head -n1)
                echo -e "${GREEN}Latest Deployment:${NC} $(basename "$latest_deploy")"
            fi
        else
            echo -e "${YELLOW}No deployment log directory${NC}"
        fi
        
        echo ""
        
        if [[ -d "$ERROR_LOG_DIR" ]]; then
            local error_count=$(ls "$ERROR_LOG_DIR"/*.log 2>/dev/null | wc -l)
            error_count=${error_count:-0}
            echo -e "${RED}Error Logs:${NC} $error_count files"
            if [[ $error_count -gt 0 ]]; then
                local latest_error=$(ls -t "$ERROR_LOG_DIR"/*.log 2>/dev/null | head -n1)
                echo -e "${RED}Latest Error:${NC} $(basename "$latest_error")"
            fi
        else
            echo -e "${YELLOW}No error log directory${NC}"
        fi
        
        echo ""
        echo -e "${BLUE}Disk Usage:${NC}"
        du -sh "$LOG_DIR" 2>/dev/null || echo "Cannot calculate disk usage"
    else
        echo -e "${YELLOW}Log directory does not exist: $LOG_DIR${NC}"
        echo "Run a deployment first to create logs"
    fi
}

# Main execution
case "${1:-help}" in
    "errors")
        list_errors
        ;;
    "deployments")
        list_deployments
        ;;
    "latest")
        show_latest
        ;;
    "tail")
        tail_latest
        ;;
    "clean")
        clean_logs
        ;;
    "summary")
        show_summary
        ;;
    "help"|"-h"|"--help")
        show_help
        ;;
    *)
        echo -e "${RED}Unknown command: $1${NC}"
        echo ""
        show_help
        exit 1
        ;;
esac
