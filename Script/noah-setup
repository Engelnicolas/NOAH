#!/usr/bin/env python3
"""
NOAH Quick Setup Script
======================
Automated setup and validation script for NOAH project

Features:
- Environment validation
- Dependencies installation
- Requirements checking
- Quick deployment preparation

Author: NOAH Team
Version: 2.0.0
"""

import os
import sys
import subprocess
import argparse
from pathlib import Path
from typing import List, Tuple


class Colors:
    GREEN = "\033[92m"
    RED = "\033[91m"
    YELLOW = "\033[93m"
    BLUE = "\033[94m"
    PURPLE = "\033[95m"
    CYAN = "\033[96m"
    END = "\033[0m"
    BOLD = "\033[1m"


class NoahSetup:
    def __init__(self, verbose: bool = False):
        self.verbose = verbose
        self.script_dir = Path(__file__).parent
        self.project_root = self.script_dir.parent
        self.success_count = 0
        self.total_steps = 0

    def print_banner(self):
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print(
            "███╗   ██╗ ██████╗  █████╗ ██╗  ██╗    ███████╗███████╗████████╗██╗   ██╗██████╗ "
        )
        print(
            "████╗  ██║██╔═══██╗██╔══██╗██║  ██║    ██╔════╝██╔════╝╚══██╔══╝██║   ██║██╔══██╗"
        )
        print(
            "██╔██╗ ██║██║   ██║███████║███████║    ███████╗█████╗     ██║   ██║   ██║██████╔╝"
        )
        print(
            "██║╚██╗██║██║   ██║██╔══██║██╔══██║    ╚════██║██╔══╝     ██║   ██║   ██║██╔═══╝ "
        )
        print(
            "██║ ╚████║╚██████╔╝██║  ██║██║  ██║    ███████║███████╗   ██║   ╚██████╔╝██║     "
        )
        print(
            "╚═╝  ╚═══╝ ╚═════╝ ╚═╝  ╚═╝╚═╝  ╚═╝    ╚══════╝╚══════╝   ╚═╝    ╚═════╝ ╚═╝     "
        )
        print(f"{Colors.END}")
        print(f"{Colors.BOLD}NOAH Quick Setup Script{Colors.END}")
        print("=" * 60)

    def log(self, message: str, level: str = "INFO"):
        colors = {
            "INFO": Colors.BLUE,
            "SUCCESS": Colors.GREEN,
            "WARNING": Colors.YELLOW,
            "ERROR": Colors.RED,
            "STEP": Colors.PURPLE,
        }
        color = colors.get(level, Colors.BLUE)
        print(f"{color}[{level}]{Colors.END} {message}")

    def run_command(self, command: List[str], description: str = "") -> bool:
        """Run a command and return success status"""
        self.total_steps += 1

        if description:
            self.log(f"Step {self.total_steps}: {description}", "STEP")

        if self.verbose:
            self.log(f"Running: {' '.join(command)}")

        try:
            result = subprocess.run(
                command,
                cwd=self.project_root,
                capture_output=not self.verbose,
                text=True,
                timeout=300,
            )

            if result.returncode == 0:
                self.success_count += 1
                self.log("✓ Success", "SUCCESS")
                return True
            else:
                self.log(f"✗ Failed with code {result.returncode}", "ERROR")
                if not self.verbose and result.stderr:
                    self.log(f"Error: {result.stderr.strip()}", "ERROR")
                return False

        except subprocess.TimeoutExpired:
            self.log("✗ Command timed out", "ERROR")
            return False
        except Exception as e:
            self.log(f"✗ Exception: {str(e)}", "ERROR")
            return False

    def check_prerequisites(self) -> bool:
        """Check system prerequisites"""
        self.log("Checking system prerequisites...", "INFO")

        # Check Python version
        if not self.run_command([sys.executable, "--version"], "Check Python version"):
            return False

        # Check if required scripts exist
        scripts_to_check = [
            "Script/noah",
            "Script/noah-deps-manager",
            "Script/noah-tech-requirements",
            "Script/helm-values-validator.py",
        ]

        for script in scripts_to_check:
            script_path = self.project_root / script
            if not script_path.exists():
                self.log(f"Missing script: {script}", "ERROR")
                return False

        self.log("All prerequisites check passed", "SUCCESS")
        return True

    def install_dependencies(self, include_dev: bool = False) -> bool:
        """Install Python dependencies"""
        self.log("Installing Python dependencies...", "INFO")

        cmd = [sys.executable, "Script/noah-deps-manager", "--install-only"]
        if include_dev:
            cmd.append("--dev")
        if self.verbose:
            cmd.append("--verbose")

        return self.run_command(cmd, "Install dependencies")

    def validate_requirements(self, profile: str = "minimal") -> bool:
        """Validate technical requirements"""
        self.log(f"Validating technical requirements for {profile} profile...", "INFO")

        cmd = [sys.executable, "Script/noah-tech-requirements", "--profile", profile]

        # Don't fail if requirements check fails (might be in development environment)
        result = self.run_command(cmd, f"Check {profile} requirements")
        if not result:
            self.log("Requirements check failed, but continuing...", "WARNING")

        return True  # Don't fail setup for requirements

    def validate_configuration(self) -> bool:
        """Validate project configuration"""
        self.log("Validating project configuration...", "INFO")

        # Check Helm values
        if not self.run_command(
            [sys.executable, "Script/helm-values-validator.py"], "Validate Helm values"
        ):
            return False

        # Check if main CLI works
        if not self.run_command(["./Script/noah", "--help"], "Test main CLI"):
            return False

        return True

    def prepare_environment(self) -> bool:
        """Prepare development environment"""
        self.log("Preparing development environment...", "INFO")

        # Make scripts executable
        scripts_to_chmod = [
            "Script/noah",
            "Script/noah-deps-manager",
            "Script/noah-tech-requirements",
        ]

        for script in scripts_to_chmod:
            script_path = self.project_root / script
            if script_path.exists():
                if not self.run_command(
                    ["chmod", "+x", str(script_path)], f"Make {script} executable"
                ):
                    return False

        return True

    def run_quick_tests(self) -> bool:
        """Run quick validation tests"""
        self.log("Running quick validation tests...", "INFO")

        # Test CLI commands
        commands_to_test = [
            (["./Script/noah", "--version"], "Test CLI version"),
            (["./Script/noah", "deps", "--help"], "Test deps command"),
            (["./Script/noah", "requirements", "--help"], "Test requirements command"),
        ]

        for cmd, description in commands_to_test:
            if not self.run_command(cmd, description):
                return False

        return True

    def show_summary(self) -> None:
        """Show setup summary"""
        print(f"\n{Colors.BOLD}Setup Summary{Colors.END}")
        print("=" * 40)
        print(f"Total steps: {self.total_steps}")
        print(f"Successful: {self.success_count}")
        print(f"Failed: {self.total_steps - self.success_count}")

        if self.success_count == self.total_steps:
            print(f"\n{Colors.GREEN}🎉 Setup completed successfully!{Colors.END}")
        else:
            print(f"\n{Colors.YELLOW}⚠ Setup completed with some issues{Colors.END}")

    def show_next_steps(self) -> None:
        """Show next steps for user"""
        print(f"\n{Colors.BOLD}Next Steps{Colors.END}")
        print("=" * 40)
        print(f"{Colors.CYAN}1. Validate your environment:{Colors.END}")
        print("   ./Script/noah requirements --profile minimal")
        print("")
        print(f"{Colors.CYAN}2. Check dependencies:{Colors.END}")
        print("   ./Script/noah deps --report")
        print("")
        print(f"{Colors.CYAN}3. Validate configuration:{Colors.END}")
        print("   ./Script/noah validate --scope all")
        print("")
        print(f"{Colors.CYAN}4. Deploy infrastructure:{Colors.END}")
        print("   ./Script/noah infra setup")
        print("   ./Script/noah infra deploy")
        print("")
        print(f"{Colors.CYAN}5. Check deployment status:{Colors.END}")
        print("   ./Script/noah infra status")
        print("")
        print(f"{Colors.GREEN}For help with any command, use --help{Colors.END}")
        print("Example: ./Script/noah infra --help")

    def full_setup(self, profile: str = "minimal", include_dev: bool = False) -> bool:
        """Run complete setup process"""
        self.log("Starting NOAH setup process...", "INFO")

        steps = [
            (self.check_prerequisites, "Check prerequisites"),
            (self.prepare_environment, "Prepare environment"),
            (lambda: self.install_dependencies(include_dev), "Install dependencies"),
            (lambda: self.validate_requirements(profile), "Validate requirements"),
            (self.validate_configuration, "Validate configuration"),
            (self.run_quick_tests, "Run quick tests"),
        ]

        for step_func, step_name in steps:
            self.log(f"Starting: {step_name}", "INFO")
            if not step_func():
                self.log(f"Failed: {step_name}", "ERROR")
                return False

        return True


def main():
    """Main function"""
    parser = argparse.ArgumentParser(description="NOAH Quick Setup Script")
    parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )
    parser.add_argument(
        "--profile",
        choices=["minimal", "root"],
        default="minimal",
        help="Deployment profile to validate against",
    )
    parser.add_argument(
        "--dev", action="store_true", help="Include development dependencies"
    )
    parser.add_argument(
        "--deps-only", action="store_true", help="Only install dependencies"
    )
    parser.add_argument(
        "--check-only", action="store_true", help="Only run validation checks"
    )

    args = parser.parse_args()

    setup = NoahSetup(verbose=args.verbose)
    setup.print_banner()

    success = False

    if args.deps_only:
        success = setup.install_dependencies(include_dev=args.dev)
    elif args.check_only:
        success = (
            setup.validate_requirements(args.profile)
            and setup.validate_configuration()
            and setup.run_quick_tests()
        )
    else:
        success = setup.full_setup(profile=args.profile, include_dev=args.dev)

    setup.show_summary()

    if success:
        setup.show_next_steps()
        sys.exit(0)
    else:
        print(
            f"\n{Colors.RED}❌ Setup failed. Please check the errors above.{Colors.END}"
        )
        sys.exit(1)


if __name__ == "__main__":
    main()
