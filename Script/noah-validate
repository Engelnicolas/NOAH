#!/bin/bash

# =======================
# NOAH - Unified Validation Script
# =======================
# Combines: validate_fixes.sh, validate_project.sh, validate_charts.sh
# Purpose: Single script for all validation tasks

set -euo pipefail

# Script metadata
SCRIPT_VERSION="3.0.0"
SCRIPT_NAME="noah-validate"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Configuration
STRICT_MODE=false
FIX_ISSUES=false
VERBOSE=false
SCOPE="all"  # all, yaml, ansible, helm, scripts

# Color codes
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[0;33m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# Counters
success=0
errors=0
warnings=0

# Logging functions
log_success() {
    echo -e "${GREEN}✅ $1${NC}"
    success=$((success + 1))
}

log_error() {
    echo -e "${RED}❌ $1${NC}"
    errors=$((errors + 1))
}

log_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
    warnings=$((warnings + 1))
}

log_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

# Help function
show_help() {
    cat << 'EOF'
NOAH Unified Validation Script

USAGE:
    ./noah-validate [OPTIONS]

OPTIONS:
    -s, --scope SCOPE       Validation scope: all, yaml, ansible, helm, scripts (default: all)
    -f, --fix              Attempt to fix issues automatically
    -v, --verbose          Enable verbose output
    --strict               Enable strict mode (exit on first error)
    -h, --help             Show this help message

EXAMPLES:
    ./noah-validate                    # Validate everything
    ./noah-validate --scope yaml      # Only validate YAML files
    ./noah-validate --scope helm      # Only validate Helm charts
    ./noah-validate --fix             # Validate and fix issues
    ./noah-validate --verbose         # Verbose output

EOF
}

# YAML Validation
validate_yaml() {
    log_info "Validating YAML files..."
    
    # Key YAML files to check
    yaml_files=(
        "Ansible/main.yml"
        "Ansible/inventory"
        "Ansible/vars/global.yml"
        "mkdocs.yml"
    )
    
    # Add all Helm Chart.yaml and values.yaml files
    while IFS= read -r -d '' file; do
        yaml_files+=("$file")
    done < <(find Helm/ -name "Chart.yaml" -o -name "values.yaml" -print0 2>/dev/null || true)
    
    for file in "${yaml_files[@]}"; do
        if [ -f "$file" ]; then
            if python3 -c "import yaml; yaml.safe_load(open('$file'))" 2>/dev/null; then
                log_success "YAML syntax valid: $file"
            else
                log_error "YAML syntax error: $file"
                if [ "$FIX_ISSUES" = true ]; then
                    log_info "Attempting to fix YAML syntax in $file..."
                    python3 "${SCRIPT_DIR}/noah-fix.py" "$file" 2>/dev/null || true
                fi
            fi
        else
            log_warning "Missing YAML file: $file"
        fi
    done
    
    # Check for trailing spaces
    trailing_spaces=$(find . -name "*.yml" -o -name "*.yaml" | grep -v ".git" | grep -v "charts/" | xargs grep -l '[[:space:]]$' 2>/dev/null || true)
    if [ -z "$trailing_spaces" ]; then
        log_success "No trailing spaces in YAML files"
    else
        log_error "Files with trailing spaces: $trailing_spaces"
        if [ "$FIX_ISSUES" = true ]; then
            log_info "Fixing trailing spaces..."
            find . -name "*.yml" -o -name "*.yaml" | grep -v ".git" | xargs sed -i 's/[[:space:]]*$//' 2>/dev/null || true
        fi
    fi
}

# Ansible Validation
validate_ansible() {
    log_info "Validating Ansible configuration..."
    
    cd Ansible || { log_error "Ansible directory not found"; return 1; }
    
    # Test inventory parsing
    if ansible-inventory --list >/dev/null 2>&1; then
        log_success "Ansible inventory parses correctly"
    else
        log_error "Ansible inventory has errors"
    fi
    
    # Test playbook syntax
    if ansible-playbook --syntax-check main.yml -i inventory >/dev/null 2>&1; then
        log_success "Ansible playbook syntax is valid"
    else
        log_error "Ansible playbook has syntax errors"
    fi
    
    cd - >/dev/null
}

# Helm Charts Validation
validate_helm() {
    log_info "Validating Helm charts..."
    
    local charts_found=0
    local charts_valid=0
    
    for chart_dir in Helm/*/; do
        if [ -d "$chart_dir" ] && [ -f "${chart_dir}Chart.yaml" ]; then
            ((charts_found++))
            chart_name=$(basename "$chart_dir")
            
            # Validate Chart.yaml syntax
            if python3 -c "import yaml; yaml.safe_load(open('${chart_dir}Chart.yaml'))" 2>/dev/null; then
                log_success "Chart.yaml valid: $chart_name"
            else
                log_error "Chart.yaml invalid: $chart_name"
                continue
            fi
            
            # Check for required files
            if [ -f "${chart_dir}values.yaml" ]; then
                log_success "values.yaml exists: $chart_name"
            else
                log_warning "values.yaml missing: $chart_name"
            fi
            
            # Helm lint
            if command -v helm >/dev/null 2>&1; then
                if helm lint "$chart_dir" >/dev/null 2>&1; then
                    log_success "Helm lint passed: $chart_name"
                    ((charts_valid++))
                else
                    log_error "Helm lint failed: $chart_name"
                fi
            else
                log_warning "Helm not installed, skipping lint for: $chart_name"
            fi
        fi
    done
    
    log_info "Validated $charts_valid/$charts_found Helm charts"
}

# Scripts Validation
validate_scripts() {
    log_info "Validating shell scripts..."
    
    local scripts_found=0
    local scripts_valid=0
    
    for script in Script/*.sh Test/*.sh; do
        if [ -f "$script" ]; then
            ((scripts_found++))
            if bash -n "$script" 2>/dev/null; then
                log_success "Script syntax valid: $(basename "$script")"
                ((scripts_valid++))
            else
                log_error "Script syntax error: $(basename "$script")"
            fi
        fi
    done
    
    log_info "Validated $scripts_valid/$scripts_found shell scripts"
}

# File Structure Validation
validate_structure() {
    log_info "Validating project structure..."
    
    required_files=(
        "README.md"
        "LICENSE"
        "CONTRIBUTING.md"
        "mkdocs.yml"
        "Ansible/main.yml"
        "Ansible/inventory"
        "docs/index.md"
        "docs/USER_GUIDE.md"
    )
    
    for file in "${required_files[@]}"; do
        if [ -f "$file" ]; then
            log_success "Required file exists: $file"
        else
            log_error "Missing required file: $file"
        fi
    done
    
    # Check for old Docs/ directory
    if [ -d "Docs" ]; then
        log_error "Old 'Docs/' directory exists - should be merged into 'docs/'"
    else
        log_success "Documentation properly merged into 'docs/'"
    fi
}

# Main validation logic
run_validation() {
    echo "🔍 NOAH Unified Validation"
    echo "=========================="
    echo "Scope: $SCOPE"
    echo "Fix issues: $FIX_ISSUES"
    echo "Strict mode: $STRICT_MODE"
    echo ""
    
    case "$SCOPE" in
        "all")
            validate_structure
            validate_yaml
            validate_ansible
            validate_helm
            validate_scripts
            ;;
        "yaml")
            validate_yaml
            ;;
        "ansible")
            validate_ansible
            ;;
        "helm")
            validate_helm
            ;;
        "scripts")
            validate_scripts
            ;;
        *)
            log_error "Invalid scope: $SCOPE"
            show_help
            exit 1
            ;;
    esac
    
    # Summary
    echo ""
    echo "📊 Validation Summary"
    echo "===================="
    echo -e "✅ Successes: ${GREEN}$success${NC}"
    echo -e "⚠️  Warnings:  ${YELLOW}$warnings${NC}"
    echo -e "❌ Errors:    ${RED}$errors${NC}"
    
    if [ $errors -eq 0 ]; then
        echo -e "\n🎉 ${GREEN}All validations passed!${NC}"
        exit 0
    else
        echo -e "\n💥 ${RED}Validation failed with $errors errors${NC}"
        if [ "$STRICT_MODE" = true ]; then
            exit 1
        fi
    fi
}

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        -s|--scope)
            SCOPE="$2"
            shift 2
            ;;
        -f|--fix)
            FIX_ISSUES=true
            shift
            ;;
        -v|--verbose)
            VERBOSE=true
            shift
            ;;
        --strict)
            STRICT_MODE=true
            shift
            ;;
        -h|--help)
            show_help
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
done

# Run validation
run_validation
