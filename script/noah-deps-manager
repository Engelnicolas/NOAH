#!/usr/bin/env python3
"""
NOAH Dependencies Manager
========================
Manages Python dependencies for the NOAH project

Features:
- Install dependencies with environment detection
- Validate installed packages
- Update dependencies safely
- Check for security vulnerabilities
- Generate dependency reports

Author: NOAH Team
Version: 2.0.0
"""

import argparse
import json
import os
import subprocess
import sys
import tempfile
from pathlib import Path
from typing import Dict, List, Optional, Tuple


class Colors:
    GREEN = "\033[92m"
    RED = "\033[91m"
    YELLOW = "\033[93m"
    BLUE = "\033[94m"
    PURPLE = "\033[95m"
    CYAN = "\033[96m"
    END = "\033[0m"
    BOLD = "\033[1m"


class DependencyManager:
    def __init__(self, verbose: bool = False):
        self.verbose = verbose
        self.script_dir = Path(__file__).parent
        self.requirements_file = self.script_dir / "requirements.txt"
        self.retry_attempts = 0  # Track retry attempts to prevent infinite loops
        self.max_retry_attempts = 3  # Maximum number of retry attempts

    def print_banner(self):
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print("██████╗ ███████╗██████╗ ███████╗    ███╗   ███╗ ██████╗ ██████╗ ")
        print("██╔══██╗██╔════╝██╔══██╗██╔════╝    ████╗ ████║██╔════╝ ██╔══██╗")
        print("██║  ██║█████╗  ██████╔╝███████╗    ██╔████╔██║██║  ███╗██████╔╝")
        print("██║  ██║██╔══╝  ██╔═══╝ ╚════██║    ██║╚██╔╝██║██║   ██║██╔══██╗")
        print("██████╔╝███████╗██║     ███████║    ██║ ╚═╝ ██║╚██████╔╝██║  ██║")
        print("╚═════╝ ╚══════╝╚═╝     ╚══════╝    ╚═╝     ╚═╝ ╚═════╝ ╚═╝  ╚═╝")
        print(f"{Colors.END}")
        print(f"{Colors.BOLD}NOAH Dependencies Manager{Colors.END}")
        print("=" * 50)

    def reset_retry_counter(self):
        """Reset the retry attempt counter for fresh installations."""
        self.retry_attempts = 0

    def log(self, message: str, level: str = "INFO"):
        colors = {
            "INFO": Colors.BLUE,
            "SUCCESS": Colors.GREEN,
            "WARNING": Colors.YELLOW,
            "ERROR": Colors.RED,
        }
        color = colors.get(level, Colors.BLUE)
        print(f"{color}[{level}]{Colors.END} {message}")

    def run_command(
        self, command: List[str], capture_output: bool = True
    ) -> Tuple[bool, str]:
        """Run a command and return success status and output"""
        try:
            if self.verbose:
                self.log(f"Running: {' '.join(command)}")

            result = subprocess.run(
                command, capture_output=capture_output, text=True, timeout=300
            )

            if result.returncode == 0:
                return True, result.stdout.strip()
            else:
                return False, result.stderr.strip()

        except subprocess.TimeoutExpired:
            return False, "Command timed out"
        except Exception as e:
            return False, str(e)

    def check_python_version(self) -> bool:
        """Check if Python version meets requirements"""
        self.log("Checking Python version...")

        version_info = sys.version_info
        required_version = (3, 8)

        if version_info >= required_version:
            self.log(
                f"Python {version_info.major}.{version_info.minor}.{version_info.micro} ✓",
                "SUCCESS",
            )
            return True
        else:
            self.log(
                f"Python {version_info.major}.{version_info.minor}.{version_info.micro} < {required_version[0]}.{required_version[1]} required",
                "ERROR",
            )
            return False

    def check_pip_version(self) -> bool:
        """Check if pip version is adequate"""
        self.log("Checking pip version...")

        success, output = self.run_command([sys.executable, "-m", "pip", "--version"])
        if success:
            self.log(f"pip version: {output}", "SUCCESS")
            return True
        else:
            self.log(f"pip check failed: {output}", "ERROR")
            return False

    def upgrade_pip(self) -> bool:
        """Upgrade pip to latest version"""
        self.log("Upgrading pip...")

        success, output = self.run_command(
            [sys.executable, "-m", "pip", "install", "--upgrade", "pip"]
        )

        if success:
            self.log("pip upgraded successfully", "SUCCESS")
            return True
        else:
            self.log(f"pip upgrade failed: {output}", "ERROR")
            return False

    def auto_install_missing_dependencies(self) -> bool:
        """Automatically check and install missing dependencies with retry mechanism."""
        # Reset retry attempts for fresh auto-install calls
        if self.retry_attempts == 0:
            self.log("🔍 Checking for missing dependencies...")
        else:
            self.log(f"🔍 Retry check for missing dependencies (attempt {self.retry_attempts}/{self.max_retry_attempts})...")

        if not self.requirements_file.exists():
            self.log(f"Requirements file not found: {self.requirements_file}", "ERROR")
            return False

        try:
            # Parse requirements file
            missing_modules = []
            installed_modules = []

            with open(self.requirements_file, "r", encoding="utf-8") as f:
                requirements = []
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("#"):
                        # Extract package name
                        package_name = self._extract_package_name(line)
                        if package_name:
                            requirements.append((package_name, line))

            # Check each requirement
            self.log(f"📋 Checking {len(requirements)} dependencies...")
            for package_name, requirement_line in requirements:
                if not self._is_module_installed(package_name):
                    missing_modules.append((package_name, requirement_line))
                else:
                    installed_modules.append(package_name)
                    if self.verbose:
                        self.log(f"✓ {package_name} already installed", "SUCCESS")

            # Report status
            self.log(
                f"📊 Status: {len(installed_modules)} installed, {len(missing_modules)} missing"
            )

            # Install missing modules
            if missing_modules:
                self.log(
                    f"📦 Installing {len(missing_modules)} missing dependencies..."
                )
                install_success = self._install_missing_modules_with_retry(missing_modules)
                
                # Final comprehensive check after installation
                if install_success:
                    self.log("🔍 Performing final verification of all dependencies...")
                    final_check_success = self._perform_final_dependency_check(requirements)
                    
                    if not final_check_success:
                        if self.retry_attempts < self.max_retry_attempts:
                            self.log(f"⚠️ Final verification detected issues. Attempting full retry ({self.retry_attempts + 1}/{self.max_retry_attempts})...", "WARNING")
                            self.retry_attempts += 1
                            return self._retry_auto_install()
                        else:
                            self.log(f"❌ Maximum retry attempts ({self.max_retry_attempts}) reached. Stopping to prevent infinite loops.", "ERROR")
                            return False
                    
                    return True
                else:
                    if self.retry_attempts < self.max_retry_attempts:
                        self.log(f"❌ Installation failed. Attempting full retry ({self.retry_attempts + 1}/{self.max_retry_attempts})...", "ERROR")
                        self.retry_attempts += 1
                        return self._retry_auto_install()
                    else:
                        self.log(f"❌ Maximum retry attempts ({self.max_retry_attempts}) reached. Stopping to prevent infinite loops.", "ERROR")
                        return False
            else:
                self.log("✅ All dependencies are already installed", "SUCCESS")
                return True

        except Exception as e:
            self.log(f"Error during dependency check: {e}", "ERROR")
            return False

    def _extract_package_name(self, requirement_line: str) -> str:
        """Extract package name from requirement line."""
        for separator in [">=", "==", "<=", ">", "<", "!=", "~=", "[", ";"]:
            if separator in requirement_line:
                requirement_line = requirement_line.split(separator)[0]
        return requirement_line.strip()

    def _is_module_installed(self, module_name: str) -> bool:
        """Check if a Python module is installed."""
        try:
            import_name = self._get_import_name(module_name)
            __import__(import_name)
            return True
        except ImportError:
            return False

    def _get_import_name(self, package_name: str) -> str:
        """Convert package name to import name for special cases."""
        mapping = {
            "pyyaml": "yaml",
            "pillow": "PIL",
            "beautifulsoup4": "bs4",
            "python-dateutil": "dateutil",
            "msgpack-python": "msgpack",
            "pyyaml-include": "yamlinclude",
            "prometheus-client": "prometheus_client",
            "memory-profiler": "memory_profiler",
            "pytest-cov": "pytest_cov",
            "pytest-mock": "pytest_mock",
            "python-dotenv": "dotenv",  # python-dotenv imports as 'dotenv'
        }
        return mapping.get(package_name.lower(), package_name.replace("-", "_"))

    def _install_missing_modules_with_retry(self, missing_modules: list) -> bool:
        """Install missing modules with retry mechanism."""
        max_retries = 3
        success_count = 0
        failed_modules = []

        for i, (package_name, requirement_line) in enumerate(missing_modules, 1):
            self.log(f"[{i}/{len(missing_modules)}] Installing {package_name}...")

            for attempt in range(max_retries):
                try:
                    cmd = [sys.executable, "-m", "pip", "install", requirement_line]
                    success, output = self.run_command(cmd)

                    if success:
                        self.log(f"✅ {package_name} installed successfully", "SUCCESS")
                        success_count += 1
                        break
                    else:
                        if attempt == max_retries - 1:
                            self.log(
                                f"❌ Failed to install {package_name} after {max_retries} attempts",
                                "ERROR",
                            )
                            failed_modules.append(package_name)
                        else:
                            self.log(
                                f"⚠️ Attempt {attempt + 1} failed for {package_name}, retrying...",
                                "WARNING",
                            )
                            import time

                            time.sleep(2)

                except Exception as e:
                    if attempt == max_retries - 1:
                        self.log(f"❌ Error installing {package_name}: {e}", "ERROR")
                        failed_modules.append(package_name)

        # Final report
        total = len(missing_modules)
        self.log(f"📋 Installation summary: {success_count}/{total} successful")

        if failed_modules:
            self.log(f"❌ Failed modules: {', '.join(failed_modules)}", "ERROR")
            
            # Attempt automatic retry with --auto-install if there are errors
            self.log("🔄 Attempting automatic retry with enhanced installation method...", "WARNING")
            retry_success = self._retry_failed_installations(failed_modules)
            
            if retry_success:
                self.log("✅ Retry installation completed successfully", "SUCCESS")
                return True
            else:
                self.log("❌ Retry installation failed. Manual intervention may be required.", "ERROR")
                return False
        else:
            self.log("✅ All missing dependencies installed successfully", "SUCCESS")
            return True

    def _retry_failed_installations(self, failed_modules: list) -> bool:
        """Retry failed installations using alternative methods."""
        self.log(f"🔄 Retrying installation for {len(failed_modules)} failed modules...")
        
        success_count = 0
        final_failed = []
        
        for module in failed_modules:
            self.log(f"🔄 Retrying {module} with enhanced method...")
            
            # Try different installation strategies
            strategies = [
                # Strategy 1: Install with no-cache and force-reinstall
                [sys.executable, "-m", "pip", "install", "--no-cache-dir", "--force-reinstall", module],
                # Strategy 2: Install with user flag (if not in virtual env)
                [sys.executable, "-m", "pip", "install", "--user", module] if not hasattr(sys, 'real_prefix') and not sys.base_prefix != sys.prefix else None,
                # Strategy 3: Install with no-deps first, then install deps
                [sys.executable, "-m", "pip", "install", "--no-deps", module],
                # Strategy 4: Try with different index
                [sys.executable, "-m", "pip", "install", "-i", "https://pypi.org/simple/", module]
            ]
            
            # Filter out None strategies
            strategies = [s for s in strategies if s is not None]
            
            module_installed = False
            for i, strategy in enumerate(strategies, 1):
                try:
                    self.log(f"  Strategy {i}/{len(strategies)}: {' '.join(strategy[3:])}")
                    success, output = self.run_command(strategy)
                    
                    if success:
                        # Verify the module is actually importable
                        if self._is_module_installed(module):
                            self.log(f"✅ {module} successfully installed with strategy {i}", "SUCCESS")
                            success_count += 1
                            module_installed = True
                            break
                        else:
                            self.log(f"⚠️ {module} installed but not importable, trying next strategy...", "WARNING")
                    else:
                        self.log(f"⚠️ Strategy {i} failed for {module}: {output[:100]}...", "WARNING")
                        
                except Exception as e:
                    self.log(f"⚠️ Strategy {i} error for {module}: {str(e)[:100]}...", "WARNING")
            
            if not module_installed:
                final_failed.append(module)
                self.log(f"❌ All strategies failed for {module}", "ERROR")
        
        # Final retry report
        self.log(f"🔄 Retry summary: {success_count}/{len(failed_modules)} recovered")
        
        if final_failed:
            self.log(f"❌ Still failed after retry: {', '.join(final_failed)}", "ERROR")
            self.log("💡 Manual troubleshooting suggestions:", "INFO")
            for module in final_failed:
                self.log(f"  - Try: python -m pip install --upgrade --force-reinstall {module}", "INFO")
                self.log(f"  - Check if {module} has system dependencies that need to be installed", "INFO")
            return False
        else:
            self.log("✅ All previously failed modules have been successfully installed", "SUCCESS")
            return True

    def _perform_final_dependency_check(self, requirements: list) -> bool:
        """Perform a final comprehensive check of all dependencies with graceful handling."""
        self.log("🔍 Final dependency verification (graceful mode)...")
        
        missing_critical = []
        missing_optional = []
        total_checked = 0
        
        # Define critical dependencies that must be present
        critical_deps = {'psutil', 'click', 'requests'}
        
        for package_name, requirement_line in requirements:
            total_checked += 1
            if not self._is_module_installed(package_name):
                if package_name.lower() in critical_deps:
                    missing_critical.append(package_name)
                    self.log(f"❌ Critical dependency {package_name} still missing", "ERROR")
                else:
                    missing_optional.append(package_name)
                    self.log(f"⚠️ Optional dependency {package_name} missing (non-critical)", "WARNING")
            elif self.verbose:
                self.log(f"✅ {package_name} verified", "SUCCESS")
        
        # Only fail if critical dependencies are missing
        if missing_critical:
            self.log(f"❌ Final check failed: {len(missing_critical)} critical dependencies missing", "ERROR")
            self.log(f"Critical missing: {', '.join(missing_critical)}", "ERROR")
            return False
        elif missing_optional:
            self.log(f"⚠️ {len(missing_optional)} optional dependencies missing but continuing", "WARNING")
            self.log(f"Optional missing: {', '.join(missing_optional)}", "WARNING")
            self.log(f"✅ Critical dependencies verified: {total_checked - len(missing_optional)}/{total_checked}", "SUCCESS")
            return True
        else:
            self.log(f"✅ Final check passed: All {total_checked} dependencies verified", "SUCCESS")
            return True
    
    def _retry_auto_install(self) -> bool:
        """Retry the entire auto-install process once more with safeguards."""
        self.log(f"🔄 Attempting complete retry of dependency installation (attempt {self.retry_attempts}/{self.max_retry_attempts})...", "WARNING")
        
        # Prevent infinite recursion by using a direct installation approach instead of subprocess
        if self.retry_attempts >= self.max_retry_attempts:
            self.log(f"❌ Maximum retry attempts ({self.max_retry_attempts}) reached. Aborting retry.", "ERROR")
            return False
        
        try:
            # Direct retry approach - re-parse requirements and install missing ones
            self.log("🔄 Re-checking and installing dependencies directly...")
            
            if not self.requirements_file.exists():
                self.log(f"Requirements file not found: {self.requirements_file}", "ERROR")
                return False

            # Parse requirements file again
            missing_modules = []
            with open(self.requirements_file, "r", encoding="utf-8") as f:
                requirements = []
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("#"):
                        package_name = self._extract_package_name(line)
                        if package_name:
                            requirements.append((package_name, line))

            # Check which modules are still missing
            for package_name, requirement_line in requirements:
                if not self._is_module_installed(package_name):
                    missing_modules.append((package_name, requirement_line))

            self.log(f"🔄 Retry found {len(missing_modules)} still missing dependencies")
            
            if missing_modules:
                # Use enhanced installation strategies directly
                return self._install_missing_modules_with_enhanced_strategies(missing_modules)
            else:
                self.log("✅ All dependencies are now installed after retry", "SUCCESS")
                return True
                
        except Exception as e:
            self.log(f"❌ Exception during retry auto-install: {e}", "ERROR")
            return False

    def _install_missing_modules_with_enhanced_strategies(self, missing_modules: list) -> bool:
        """Install missing modules using enhanced strategies for retry scenarios."""
        self.log(f"🔄 Installing {len(missing_modules)} missing modules with enhanced strategies...")
        
        success_count = 0
        failed_modules = []
        
        for i, (package_name, requirement_line) in enumerate(missing_modules, 1):
            self.log(f"[{i}/{len(missing_modules)}] Enhanced install: {package_name}...")
            
            # Enhanced strategies for retry scenario
            strategies = [
                # Strategy 1: Force reinstall with no cache
                [sys.executable, "-m", "pip", "install", "--no-cache-dir", "--force-reinstall", requirement_line],
                # Strategy 2: Install with no dependencies first
                [sys.executable, "-m", "pip", "install", "--no-deps", "--force-reinstall", package_name],
                # Strategy 3: Try with different index
                [sys.executable, "-m", "pip", "install", "-i", "https://pypi.org/simple/", "--no-cache-dir", requirement_line],
                # Strategy 4: Basic install as fallback
                [sys.executable, "-m", "pip", "install", requirement_line]
            ]
            
            module_installed = False
            for strategy_num, strategy in enumerate(strategies, 1):
                try:
                    self.log(f"  Enhanced strategy {strategy_num}/{len(strategies)}: {' '.join(strategy[3:])}")
                    success, output = self.run_command(strategy)
                    
                    if success:
                        # Verify the module is actually importable
                        if self._is_module_installed(package_name):
                            self.log(f"✅ {package_name} successfully installed with enhanced strategy {strategy_num}", "SUCCESS")
                            success_count += 1
                            module_installed = True
                            break
                        else:
                            self.log(f"⚠️ {package_name} installed but not importable, trying next strategy...", "WARNING")
                    else:
                        self.log(f"⚠️ Enhanced strategy {strategy_num} failed: {output[:100]}...", "WARNING")
                        
                except Exception as e:
                    self.log(f"⚠️ Enhanced strategy {strategy_num} error: {str(e)[:100]}...", "WARNING")
            
            if not module_installed:
                failed_modules.append(package_name)
                self.log(f"❌ All enhanced strategies failed for {package_name}", "ERROR")
        
        # Enhanced installation summary
        self.log(f"🔄 Enhanced installation summary: {success_count}/{len(missing_modules)} successful")
        
        if failed_modules:
            self.log(f"❌ Still failed after enhanced installation: {', '.join(failed_modules)}", "ERROR")
            self.log("💡 Manual intervention required for remaining modules:", "INFO")
            for module in failed_modules:
                self.log(f"  - Try manually: python -m pip install --upgrade --force-reinstall {module}", "INFO")
            return False
        else:
            self.log("✅ All modules successfully installed with enhanced strategies", "SUCCESS")
            return True

    def install_dependencies(
        self, include_dev: bool = False, upgrade: bool = False
    ) -> bool:
        """Install project dependencies"""
        self.log("Installing dependencies...")

        # Install main dependencies
        cmd = [sys.executable, "-m", "pip", "install"]
        if upgrade:
            cmd.append("--upgrade")
        cmd.extend(["-r", str(self.requirements_file)])

        success, output = self.run_command(cmd)
        if not success:
            self.log(f"Failed to install main dependencies: {output}", "ERROR")
            return False

        self.log("Main dependencies installed successfully", "SUCCESS")

        # Development dependencies are now integrated into main requirements.txt
        # Use optional dependencies section for development tools
        if include_dev:
            self.log(
                "Development dependencies are included in main requirements.txt", "INFO"
            )

        return True

    def validate_dependencies(self) -> bool:
        """Validate that all dependencies are correctly installed"""
        self.log("Validating installed dependencies...")

        # Check if pip check passes
        success, output = self.run_command([sys.executable, "-m", "pip", "check"])
        if not success:
            self.log(f"Dependency validation failed: {output}", "ERROR")
            return False

        self.log("All dependencies validated successfully", "SUCCESS")
        return True

    def validate_dependencies_gracefully(self) -> Tuple[bool, List[str]]:
        """Validate dependencies with graceful error handling
        
        Returns:
            Tuple[bool, List[str]]: (has_critical_errors, list_of_warnings)
        """
        self.log("Validating installed dependencies (graceful mode)...")
        warnings = []
        critical_errors = []

        # Check if pip check passes
        success, output = self.run_command([sys.executable, "-m", "pip", "check"])
        if not success:
            # Parse pip check output to categorize issues
            lines = output.strip().split('\n')
            for line in lines:
                if line.strip():
                    # Check if it's a critical core dependency
                    if any(critical in line.lower() for critical in ['psutil', 'click', 'requests']):
                        critical_errors.append(line.strip())
                        self.log(f"Critical dependency issue: {line.strip()}", "ERROR")
                    else:
                        warnings.append(line.strip())
                        self.log(f"Dependency warning: {line.strip()}", "WARNING")

        # Check core Python dependencies individually
        core_deps = ['psutil', 'click', 'requests', 'pyyaml', 'jsonschema']
        missing_core = []
        
        for dep in core_deps:
            try:
                __import__(dep.replace('-', '_'))
            except ImportError:
                if dep in ['psutil']:  # Critical for system monitoring
                    critical_errors.append(f"Missing critical dependency: {dep}")
                    self.log(f"Missing critical dependency: {dep}", "ERROR")
                else:
                    warnings.append(f"Missing optional dependency: {dep}")
                    self.log(f"Missing optional dependency: {dep}", "WARNING")

        if critical_errors:
            self.log(f"Found {len(critical_errors)} critical dependency errors", "ERROR")
            return False, warnings + critical_errors
        elif warnings:
            self.log(f"Found {len(warnings)} dependency warnings (non-critical)", "WARNING")
            self.log("Continuing with available dependencies...", "INFO")
            return True, warnings
        else:
            self.log("All dependencies validated successfully", "SUCCESS")
            return True, []

    def check_minimal_dependencies(self) -> bool:
        """Check only the absolutely essential dependencies for basic operations"""
        self.log("Checking minimal dependencies for basic operations...")
        
        # Only check for Python standard library + psutil (for system info)
        essential_deps = ['psutil']
        missing_essential = []
        
        for dep in essential_deps:
            try:
                __import__(dep)
                self.log(f"✅ Essential dependency {dep} available", "SUCCESS")
            except ImportError:
                missing_essential.append(dep)
                self.log(f"❌ Essential dependency {dep} missing", "ERROR")
        
        if missing_essential:
            self.log(f"Missing essential dependencies: {', '.join(missing_essential)}", "ERROR")
            self.log("Installing essential dependencies for basic operations...", "INFO")
            
            # Try to install just the essential ones
            for dep in missing_essential:
                success, output = self.run_command([
                    sys.executable, "-m", "pip", "install", dep
                ])
                if success:
                    self.log(f"✅ Installed essential dependency: {dep}", "SUCCESS")
                else:
                    self.log(f"❌ Failed to install {dep}: {output}", "ERROR")
                    return False
            
            return True
        
        self.log("All essential dependencies are available", "SUCCESS")
        return True

    def list_installed_packages(self) -> Dict[str, str]:
        """List all installed packages with versions"""
        success, output = self.run_command(
            [sys.executable, "-m", "pip", "list", "--format=json"]
        )
        if not success:
            self.log(f"Failed to list packages: {output}", "ERROR")
            return {}

        try:
            packages = json.loads(output)
            return {pkg["name"]: pkg["version"] for pkg in packages}
        except json.JSONDecodeError:
            self.log("Failed to parse package list", "ERROR")
            return {}

    def check_outdated_packages(self) -> List[Dict[str, str]]:
        """Check for outdated packages"""
        self.log("Checking for outdated packages...")

        success, output = self.run_command(
            [sys.executable, "-m", "pip", "list", "--outdated", "--format=json"]
        )
        if not success:
            self.log(f"Failed to check outdated packages: {output}", "ERROR")
            return []

        try:
            outdated = json.loads(output)
            if outdated:
                self.log(f"Found {len(outdated)} outdated packages", "WARNING")
                for pkg in outdated:
                    self.log(
                        f"  {pkg['name']}: {pkg['version']} → {pkg['latest_version']}",
                        "WARNING",
                    )
            else:
                self.log("All packages are up to date", "SUCCESS")
            return outdated
        except json.JSONDecodeError:
            self.log("Failed to parse outdated packages list", "ERROR")
            return []

    def check_security_vulnerabilities(self) -> bool:
        """Check for security vulnerabilities using safety"""
        self.log("Checking for security vulnerabilities...")

        # Try to install safety if not available
        success, _ = self.run_command([sys.executable, "-m", "pip", "show", "safety"])
        if not success:
            self.log("Installing safety for security checks...")
            success, output = self.run_command(
                [sys.executable, "-m", "pip", "install", "safety"]
            )
            if not success:
                self.log(f"Failed to install safety: {output}", "WARNING")
                return True  # Don't fail if safety can't be installed

        # Run safety check
        success, output = self.run_command([sys.executable, "-m", "safety", "check"])
        if success:
            self.log("No security vulnerabilities found", "SUCCESS")
            return True
        else:
            self.log(f"Security vulnerabilities detected: {output}", "ERROR")
            return False

    def generate_dependency_report(self) -> str:
        """Generate a detailed dependency report"""
        self.log("Generating dependency report...")

        report = []
        report.append("NOAH Dependencies Report")
        report.append("=" * 50)
        report.append(f"Python Version: {sys.version}")
        report.append(f"Platform: {sys.platform}")
        report.append("")

        # List installed packages
        packages = self.list_installed_packages()
        if packages:
            report.append("Installed Packages:")
            report.append("-" * 20)
            for name, version in sorted(packages.items()):
                report.append(f"{name:30} {version}")
            report.append("")

        # Check outdated packages
        outdated = self.check_outdated_packages()
        if outdated:
            report.append("Outdated Packages:")
            report.append("-" * 20)
            for pkg in outdated:
                report.append(
                    f"{pkg['name']:30} {pkg['version']} → {pkg['latest_version']}"
                )
            report.append("")

        return "\n".join(report)

    def save_report(self, report: str, filename: str = "dependency_report.txt"):
        """Save dependency report to file"""
        report_file = self.script_dir / filename
        try:
            with open(report_file, "w") as f:
                f.write(report)
            self.log(f"Report saved to: {report_file}", "SUCCESS")
        except Exception as e:
            self.log(f"Failed to save report: {e}", "ERROR")

    def cleanup_dependencies(self) -> bool:
        """Clean up unused dependencies"""
        self.log("Cleaning up unused dependencies...")

        # Try to install pip-autoremove if not available
        success, _ = self.run_command(
            [sys.executable, "-m", "pip", "show", "pip-autoremove"]
        )
        if not success:
            self.log("Installing pip-autoremove for cleanup...")
            success, output = self.run_command(
                [sys.executable, "-m", "pip", "install", "pip-autoremove"]
            )
            if not success:
                self.log(f"Failed to install pip-autoremove: {output}", "WARNING")
                return True

        # Run cleanup
        success, output = self.run_command(
            [sys.executable, "-m", "pip_autoremove", "--help"]
        )
        if success:
            self.log(
                "Run 'pip-autoremove' manually to clean unused dependencies", "INFO"
            )

        return True

    def update_requirements_versions(self, auto_update: bool = False) -> bool:
        """Update package versions in requirements.txt to latest available versions."""
        self.log("🔄 Checking for package version updates...")
        
        if not self.requirements_file.exists():
            self.log(f"Requirements file not found: {self.requirements_file}", "ERROR")
            return False
        
        try:
            # Read current requirements file
            with open(self.requirements_file, "r", encoding="utf-8") as f:
                original_lines = f.readlines()
            
            # Parse requirements and get outdated packages
            outdated_packages = self.check_outdated_packages()
            if not outdated_packages:
                self.log("✅ All packages are already up to date", "SUCCESS")
                return True
            
            # Create mapping of package name to latest version
            outdated_map = {pkg["name"].lower(): pkg["latest_version"] for pkg in outdated_packages}
            
            self.log(f"📦 Found {len(outdated_packages)} packages with available updates")
            
            # Process each line in requirements.txt
            updated_lines = []
            updates_made = []
            
            for line_num, line in enumerate(original_lines, 1):
                original_line = line
                stripped_line = line.strip()
                
                # Skip comments and empty lines
                if not stripped_line or stripped_line.startswith("#"):
                    updated_lines.append(original_line)
                    continue
                
                # Extract package name and current version spec
                package_name = self._extract_package_name(stripped_line)
                if not package_name:
                    updated_lines.append(original_line)
                    continue
                
                # Check if this package has an update available
                package_key = package_name.lower()
                if package_key in outdated_map:
                    latest_version = outdated_map[package_key]
                    
                    # Update the version in the line
                    updated_line = self._update_version_in_line(stripped_line, package_name, latest_version)
                    
                    if updated_line != stripped_line:
                        # Preserve original line formatting (indentation, line ending)
                        indent = len(line) - len(line.lstrip())
                        line_ending = line[len(line.rstrip()):]
                        updated_lines.append(" " * indent + updated_line + line_ending)
                        
                        updates_made.append({
                            "package": package_name,
                            "line": line_num,
                            "old": stripped_line,
                            "new": updated_line
                        })
                        
                        self.log(f"📝 Line {line_num}: {package_name} version updated", "INFO")
                    else:
                        updated_lines.append(original_line)
                else:
                    updated_lines.append(original_line)
            
            # Show summary of proposed changes
            if updates_made:
                self.log(f"📋 Proposed version updates:", "INFO")
                for update in updates_made:
                    self.log(f"  Line {update['line']}: {update['old']} → {update['new']}", "INFO")
                
                # Ask for confirmation unless auto_update is True
                if auto_update:
                    self.log("🔄 Auto-update mode: applying changes automatically", "INFO")
                    proceed = True
                else:
                    self.log("❓ Apply these updates to requirements.txt? (y/N): ", "WARNING")
                    try:
                        response = input().strip().lower()
                        proceed = response in ['y', 'yes']
                    except (EOFError, KeyboardInterrupt):
                        proceed = False
                
                if proceed:
                    # Create backup
                    backup_file = self.requirements_file.with_suffix('.txt.backup')
                    with open(backup_file, "w", encoding="utf-8") as f:
                        f.writelines(original_lines)
                    self.log(f"💾 Backup created: {backup_file}", "INFO")
                    
                    # Write updated requirements
                    with open(self.requirements_file, "w", encoding="utf-8") as f:
                        f.writelines(updated_lines)
                    
                    self.log(f"✅ Updated {len(updates_made)} package versions in requirements.txt", "SUCCESS")
                    
                    # Optionally install updated packages
                    if auto_update:
                        self.log("🔄 Installing updated packages...", "INFO")
                        # Try to install with dependency resolution checking
                        install_success = self._safe_install_updated_dependencies()
                        if install_success:
                            self.log("✅ Updated packages installed successfully", "SUCCESS")
                        else:
                            self.log("❌ Failed to install updated packages due to conflicts", "ERROR")
                            self.log("🔄 Reverting to backup requirements.txt...", "WARNING")
                            # Restore backup on failure
                            self._restore_requirements_backup()
                            return False
                    
                    return True
                else:
                    self.log("❌ Version updates cancelled by user", "WARNING")
                    return False
            else:
                self.log("✅ No version updates needed in requirements.txt", "SUCCESS")
                return True
                
        except Exception as e:
            self.log(f"❌ Error updating requirements versions: {e}", "ERROR")
            return False
    
    def _update_version_in_line(self, line: str, package_name: str, new_version: str) -> str:
        """Update the version specification in a requirements line."""
        # Common version operators
        operators = [">=", "==", "<=", ">", "<", "!=", "~="]
        
        # Find the version operator and current version
        for op in operators:
            if op in line:
                parts = line.split(op, 1)
                if len(parts) == 2:
                    package_part = parts[0].strip()
                    version_part = parts[1].strip()
                    
                    # Handle additional specifiers like [extras] or ;python_version
                    version_clean = version_part.split('[')[0].split(';')[0].split(',')[0].strip()
                    
                    # Preserve extras and environment markers
                    extras = ""
                    env_markers = ""
                    
                    if '[' in parts[1]:
                        extras_start = parts[1].find('[')
                        extras_end = parts[1].find(']', extras_start)
                        if extras_end != -1:
                            extras = parts[1][extras_start:extras_end+1]
                    
                    if ';' in parts[1]:
                        env_markers = ';' + parts[1].split(';', 1)[1]
                    
                    # Construct updated line based on operator type
                    if op == "==":
                        # Exact version: update to new version
                        return f"{package_part}{op}{new_version}{extras}{env_markers}"
                    elif op == ">=":
                        # Minimum version: update to new minimum
                        return f"{package_part}{op}{new_version}{extras}{env_markers}"
                    elif op == "~=":
                        # Compatible version: update to new compatible version
                        return f"{package_part}{op}{new_version}{extras}{env_markers}"
                    else:
                        # For other operators (<=, >, <, !=), be more conservative
                        # Only update if it makes sense
                        if op == "<=" and self._version_compare(new_version, version_clean) > 0:
                            return f"{package_part}{op}{new_version}{extras}{env_markers}"
                        elif op == ">" and self._version_compare(new_version, version_clean) > 0:
                            return f"{package_part}{op}{new_version}{extras}{env_markers}"
                        else:
                            # Keep original line for complex constraints
                            return line
                break
        
        # If no version operator found, add one with the new version
        if package_name.lower() in line.lower():
            # Simple package name without version - add latest version
            return f"{package_name}>={new_version}"
        
        return line
    
    def _version_compare(self, version1: str, version2: str) -> int:
        """Compare two version strings. Returns 1 if v1 > v2, -1 if v1 < v2, 0 if equal."""
        try:
            from packaging import version
            v1 = version.parse(version1)
            v2 = version.parse(version2)
            
            if v1 > v2:
                return 1
            elif v1 < v2:
                return -1
            else:
                return 0
        except ImportError:
            # Fallback to simple string comparison if packaging is not available
            if version1 > version2:
                return 1
            elif version1 < version2:
                return -1
            else:
                return 0
        except Exception:
            # If version parsing fails, assume they're equal
            return 0
    
    def _safe_install_updated_dependencies(self) -> bool:
        """Safely install updated dependencies with conflict detection."""
        # First, try a dry-run to check for conflicts
        self.log("🔍 Checking for dependency conflicts...", "INFO")
        
        # Use pip's dependency resolver to check for conflicts
        cmd_check = [sys.executable, "-m", "pip", "install", "--dry-run", "-r", str(self.requirements_file)]
        success, output = self.run_command(cmd_check)
        
        if not success and "ResolutionImpossible" in output:
            self.log("❌ Dependency conflicts detected in updated requirements", "ERROR")
            self.log(f"Conflict details: {output[:200]}...", "ERROR")
            return False
        
        # If dry-run passed, proceed with actual installation
        return self.install_dependencies(upgrade=True)
    
    def _restore_requirements_backup(self) -> bool:
        """Restore requirements.txt from backup file."""
        backup_file = self.requirements_file.with_suffix('.txt.backup')
        
        if backup_file.exists():
            try:
                import shutil
                shutil.copy2(backup_file, self.requirements_file)
                self.log(f"✅ Requirements.txt restored from backup", "SUCCESS")
                return True
            except Exception as e:
                self.log(f"❌ Failed to restore backup: {e}", "ERROR")
                return False
        else:
            self.log("❌ No backup file found to restore", "ERROR")
            return False

    def check_and_install_system_tools(self) -> bool:
        """Check and install Docker, kubectl, and Helm if missing"""
        self.log("🔧 Checking system tools (Docker, kubectl, Helm)...", "INFO")
        
        tools_status = {
            "docker": self.check_and_install_docker(),
            "kubectl": self.check_and_install_kubectl(),
            "helm": self.check_and_install_helm()
        }
        
        all_success = all(tools_status.values())
        
        if all_success:
            self.log("✅ All system tools are available", "SUCCESS")
        else:
            failed_tools = [tool for tool, status in tools_status.items() if not status]
            self.log(f"❌ Failed to install: {', '.join(failed_tools)}", "ERROR")
        
        return all_success

    def check_and_install_docker(self) -> bool:
        """Check if Docker is installed, install if missing"""
        self.log("🐳 Checking Docker installation...", "INFO")
        
        # Check if docker is already installed
        success, output = self.run_command(["docker", "--version"])
        if success:
            import re
            match = re.search(r"Docker version (\d+\.\d+)", output)
            if match:
                version = match.group(1)
                self.log(f"✅ Docker v{version} is already installed", "SUCCESS")
                return True
        
        # Docker not found, attempt installation
        self.log("🔧 Docker not found, attempting installation...", "INFO")
        
        # Detect OS and install accordingly
        import platform
        os_name = platform.system().lower()
        
        if os_name == "linux":
            # Check if it's Ubuntu/Debian
            try:
                with open("/etc/os-release", "r") as f:
                    os_info = f.read().lower()
                    if "ubuntu" in os_info or "debian" in os_info:
                        return self._install_docker_ubuntu()
                    elif "centos" in os_info or "rhel" in os_info or "fedora" in os_info:
                        return self._install_docker_rhel()
            except FileNotFoundError:
                pass
        
        self.log("❌ Automatic Docker installation not supported for this OS", "ERROR")
        self.log("💡 Please install Docker manually: https://docs.docker.com/get-docker/", "INFO")
        return False

    def _install_docker_ubuntu(self) -> bool:
        """Install Docker on Ubuntu/Debian systems"""
        commands = [
            ["sudo", "apt", "update"],
            ["sudo", "apt", "install", "-y", "docker.io"],
            ["sudo", "systemctl", "start", "docker"],
            ["sudo", "systemctl", "enable", "docker"],
            ["sudo", "usermod", "-aG", "docker", os.environ.get("USER", "ubuntu")]
        ]
        
        for cmd in commands:
            self.log(f"Running: {' '.join(cmd)}", "INFO")
            success, output = self.run_command(cmd)
            if not success:
                self.log(f"❌ Command failed: {output}", "ERROR")
                return False
        
        self.log("✅ Docker installed successfully", "SUCCESS")
        self.log("💡 Please log out and back in for group changes to take effect", "WARNING")
        return True

    def _install_docker_rhel(self) -> bool:
        """Install Docker on RHEL/CentOS/Fedora systems"""
        commands = [
            ["sudo", "dnf", "install", "-y", "docker"],
            ["sudo", "systemctl", "start", "docker"],
            ["sudo", "systemctl", "enable", "docker"],
            ["sudo", "usermod", "-aG", "docker", os.environ.get("USER", "user")]
        ]
        
        for cmd in commands:
            self.log(f"Running: {' '.join(cmd)}", "INFO")
            success, output = self.run_command(cmd)
            if not success:
                self.log(f"❌ Command failed: {output}", "ERROR")
                return False
        
        self.log("✅ Docker installed successfully", "SUCCESS")
        self.log("💡 Please log out and back in for group changes to take effect", "WARNING")
        return True

    def check_and_install_kubectl(self) -> bool:
        """Check if kubectl is installed, install if missing"""
        self.log("☸️ Checking kubectl installation...", "INFO")
        
        # Check if kubectl is already installed
        success, output = self.run_command(["kubectl", "version", "--client", "--short"])
        if success:
            import re
            match = re.search(r"Client Version: v(\d+\.\d+)", output)
            if match:
                version = match.group(1)
                self.log(f"✅ kubectl v{version} is already installed", "SUCCESS")
                return True
        
        # kubectl not found, attempt installation
        self.log("🔧 kubectl not found, attempting installation...", "INFO")
        
        # Download and install kubectl
        commands = [
            ["curl", "-LO", "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"],
            ["chmod", "+x", "kubectl"],
            ["sudo", "mv", "kubectl", "/usr/local/bin/"]
        ]
        
        # Use shell for the first command to handle command substitution
        self.log("Downloading latest kubectl...", "INFO")
        download_cmd = 'curl -LO "https://dl.k8s.io/release/$(curl -L -s https://dl.k8s.io/release/stable.txt)/bin/linux/amd64/kubectl"'
        success, output = self.run_command(download_cmd, shell=True)
        if not success:
            self.log(f"❌ Failed to download kubectl: {output}", "ERROR")
            return False
        
        # Make executable and move to system path
        for cmd in commands[1:]:
            self.log(f"Running: {' '.join(cmd)}", "INFO")
            success, output = self.run_command(cmd)
            if not success:
                self.log(f"❌ Command failed: {output}", "ERROR")
                return False
        
        self.log("✅ kubectl installed successfully", "SUCCESS")
        return True

    def check_and_install_helm(self) -> bool:
        """Check if Helm is installed, install if missing"""
        self.log("⚓ Checking Helm installation...", "INFO")
        
        # Check if helm is already installed
        success, output = self.run_command(["helm", "version", "--short"])
        if success:
            import re
            match = re.search(r"v(\d+\.\d+)", output)
            if match:
                version = match.group(1)
                self.log(f"✅ Helm v{version} is already installed", "SUCCESS")
                return True
        
        # Helm not found, attempt installation
        self.log("🔧 Helm not found, attempting installation...", "INFO")
        
        # Download and run Helm installation script
        install_cmd = 'curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash'
        self.log("Downloading and installing Helm...", "INFO")
        success, output = self.run_command(install_cmd, shell=True)
        
        if success:
            self.log("✅ Helm installed successfully", "SUCCESS")
            return True
        else:
            self.log(f"❌ Helm installation failed: {output}", "ERROR")
            return False

    def run_command(self, command, shell: bool = False, timeout: int = 120) -> Tuple[bool, str]:
        """Run a system command and return success status and output"""
        try:
            if isinstance(command, str) and shell:
                result = subprocess.run(
                    command,
                    shell=True,
                    capture_output=True,
                    text=True,
                    timeout=timeout
                )
            elif isinstance(command, list):
                result = subprocess.run(
                    command,
                    capture_output=True,
                    text=True,
                    timeout=timeout
                )
            else:
                return False, "Invalid command format"
            
            output = result.stdout + result.stderr
            return result.returncode == 0, output.strip()
            
        except subprocess.TimeoutExpired:
            return False, f"Command timed out after {timeout} seconds"
        except FileNotFoundError:
            return False, "Command not found"
        except Exception as e:
            return False, str(e)

    def _compare_versions(self, version1: str, version2: str) -> int:
        """Compare semantic versions"""
        def normalize(v):
            return [int(x) for x in v.split(".")]

        v1 = normalize(version1)
        v2 = normalize(version2)

        # Pad with zeros to make equal length
        max_len = max(len(v1), len(v2))
        v1 += [0] * (max_len - len(v1))
        v2 += [0] * (max_len - len(v2))

        for i in range(max_len):
            if v1[i] > v2[i]:
                return 1
            elif v1[i] < v2[i]:
                return -1
        return 0


def main():
    """Main function"""
    parser = argparse.ArgumentParser(description="NOAH Dependencies Manager")
    parser.add_argument(
        "--verbose", "-v", action="store_true", help="Enable verbose output"
    )
    parser.add_argument(
        "--dev", action="store_true", help="Include development dependencies"
    )
    parser.add_argument(
        "--upgrade", action="store_true", help="Upgrade all dependencies"
    )
    parser.add_argument(
        "--check-security",
        action="store_true",
        help="Check for security vulnerabilities",
    )
    parser.add_argument(
        "--report", action="store_true", help="Generate dependency report"
    )
    parser.add_argument(
        "--cleanup", action="store_true", help="Clean up unused dependencies"
    )
    parser.add_argument(
        "--install-only", action="store_true", help="Only install dependencies"
    )
    parser.add_argument(
        "--auto-install",
        action="store_true",
        help="Auto-check and install missing dependencies only",
    )
    parser.add_argument(
        "--update-versions",
        action="store_true",
        help="Check for and update package versions in requirements.txt",
    )
    parser.add_argument(
        "--graceful",
        action="store_true",
        help="Use graceful dependency checking (don't fail on non-critical issues)",
    )
    parser.add_argument(
        "--help-mode",
        action="store_true",
        help="Minimal checking for help operations (only check absolute essentials)",
    )
    parser.add_argument(
        "--auto-update",
        action="store_true",
        help="Automatically update package versions without confirmation",
    )
    parser.add_argument(
        "--show-updates",
        action="store_true",
        help="Show available package updates without modifying requirements.txt",
    )
    parser.add_argument(
        "--no-auto-update",
        action="store_true",
        help="Disable automatic version updates (skip auto-update on normal runs)",
    )
    parser.add_argument(
        "--check-system-tools",
        action="store_true",
        help="Check and install system tools (Docker, kubectl, Helm)",
    )

    args = parser.parse_args()

    manager = DependencyManager(verbose=args.verbose)
    manager.print_banner()

    # Check system tools mode: install Docker, kubectl, Helm if missing
    if args.check_system_tools:
        if not manager.check_and_install_system_tools():
            sys.exit(1)
        manager.log("System tools check completed successfully", "SUCCESS")
        sys.exit(0)

    # Check system requirements
    if not manager.check_python_version():
        sys.exit(1)

    if not manager.check_pip_version():
        sys.exit(1)

    # Help mode: minimal checking for basic operations
    if args.help_mode:
        if manager.check_minimal_dependencies():
            manager.log("Minimal dependencies satisfied for basic operations", "SUCCESS")
            sys.exit(0)
        else:
            manager.log("Essential dependencies missing", "ERROR")
            sys.exit(1)

    # Auto-install mode: only check and install missing dependencies (graceful by default)
    if args.auto_install:
        # Reset retry counter for fresh auto-install
        manager.reset_retry_counter()
        if not manager.auto_install_missing_dependencies():
            # In auto-install mode, be more graceful - warn instead of failing completely
            manager.log("Some dependencies may be missing but continuing with available ones...", "WARNING")
            manager.log("Use 'python script/noah-deps-manager --auto-install --graceful' for strict checking", "INFO")
        manager.log("Auto-installation completed", "SUCCESS")
        sys.exit(0)
    
    # Update versions mode: check and update package versions in requirements.txt
    if args.update_versions or args.auto_update:
        if not manager.update_requirements_versions(auto_update=args.auto_update):
            sys.exit(1)
        manager.log("Version update process completed", "SUCCESS")
        sys.exit(0)
    
    # Show updates mode: just display available updates without modifying files
    if args.show_updates:
        outdated = manager.check_outdated_packages()
        if outdated:
            manager.log(f"📦 {len(outdated)} packages have updates available:", "INFO")
            for pkg in outdated:
                manager.log(f"  • {pkg['name']}: {pkg['version']} → {pkg['latest_version']}", "INFO")
            manager.log("💡 Use --update-versions to update requirements.txt", "INFO")
        else:
            manager.log("✅ All packages are up to date", "SUCCESS")
        sys.exit(0)

    # Automatic update check: run --auto-update by default unless specific modes are used or disabled
    if not args.no_auto_update:
        manager.log("🔄 Running automatic version update check...", "INFO")
        if not manager.update_requirements_versions(auto_update=True):
            manager.log("⚠️ Automatic update failed, continuing with normal operations...", "WARNING")
        else:
            manager.log("✅ Automatic version update completed", "SUCCESS")
    else:
        manager.log("⏭️ Automatic version updates disabled by --no-auto-update", "INFO")

    # Check system tools (Docker, kubectl, Helm) and install if missing
    manager.log("🔧 Checking system tools...", "INFO")
    if not manager.check_and_install_system_tools():
        manager.log("⚠️ Some system tools are missing, but continuing with Python dependencies...", "WARNING")

    # Upgrade pip
    if not manager.upgrade_pip():
        sys.exit(1)

    # Install dependencies
    if not manager.install_dependencies(include_dev=args.dev, upgrade=args.upgrade):
        sys.exit(1)

    if args.install_only:
        manager.log("Dependencies installation completed", "SUCCESS")
        sys.exit(0)

    # Validate dependencies (graceful or strict mode)
    if args.graceful:
        is_valid, warnings = manager.validate_dependencies_gracefully()
        if not is_valid:
            manager.log("Critical dependency errors found, cannot continue", "ERROR")
            sys.exit(1)
        elif warnings:
            manager.log("Some dependencies have issues but continuing...", "WARNING")
            for warning in warnings:
                manager.log(f"  {warning}", "WARNING")
    else:
        if not manager.validate_dependencies():
            sys.exit(1)

    # Security check
    if args.check_security:
        if not manager.check_security_vulnerabilities():
            sys.exit(1)

    # Generate report
    if args.report:
        report = manager.generate_dependency_report()
        manager.save_report(report)

    # Cleanup
    if args.cleanup:
        manager.cleanup_dependencies()

    # Check for outdated packages
    manager.check_outdated_packages()

    manager.log("All dependency operations completed successfully", "SUCCESS")


if __name__ == "__main__":
    main()
