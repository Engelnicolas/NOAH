#!/usr/bin/env python3
"""
NOAH Technical Requirements Validator
Validates system requirements before deployment

Author: NOAH Team
Version: 1.0.0
"""

import os
import shutil
import subprocess
import sys
from pathlib import Path
from typing import Dict, List, Optional, Tuple

import psutil


class Colors:
    GREEN = "\033[92m"
    RED = "\033[91m"
    YELLOW = "\033[93m"
    BLUE = "\033[94m"
    PURPLE = "\033[95m"
    CYAN = "\033[96m"
    END = "\033[0m"
    BOLD = "\033[1m"


class TechnicalRequirementsValidator:
    def __init__(self, profile: str = "minimal"):
        self.profile = profile
        self.requirements = self._load_requirements()

    def _load_requirements(self) -> Dict:
        """Load requirements based on profile"""
        requirements = {
            "minimal": {
                "cpu_cores": 2,
                "ram_gb": 6,
                "storage_gb": 50,
                "kubernetes_version": "1.24",
                "helm_version": "3.10",
                "docker_version": "20.10",
                "python_version": "3.8",
            },
            "root": {
                "cpu_cores": 8,
                "ram_gb": 28,
                "storage_gb": 500,
                "kubernetes_version": "1.24",
                "helm_version": "3.10",
                "docker_version": "20.10",
                "python_version": "3.8",
            },
        }
        return requirements.get(self.profile, requirements["minimal"])

    def print_banner(self):
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print("████████╗███████╗ ██████╗██╗  ██╗    ██████╗ ███████╗ ██████╗ ███████╗")
        print("╚══██╔══╝██╔════╝██╔════╝██║  ██║    ██╔══██╗██╔════╝██╔═══██╗██╔════╝")
        print("   ██║   █████╗  ██║     ███████║    ██████╔╝█████╗  ██║   ██║███████╗")
        print("   ██║   ██╔══╝  ██║     ██╔══██║    ██╔══██╗██╔══╝  ██║▄▄ ██║╚════██║")
        print("   ██║   ███████╗╚██████╗██║  ██║    ██║  ██║███████╗╚██████╔╝███████║")
        print("   ╚═╝   ╚══════╝ ╚═════╝╚═╝  ╚═╝    ╚═╝  ╚═╝╚══════╝ ╚══▀▀═╝ ╚══════╝")
        print(f"{Colors.END}")
        print(f"{Colors.BOLD}NOAH Technical Requirements Validator{Colors.END}")
        print(f"{Colors.BLUE}Profile: {self.profile.upper()}{Colors.END}")
        print("=" * 60)

    def check_system_resources(self) -> Dict:
        """Check system hardware resources"""
        print(f"\n{Colors.BOLD}🖥️  System Resources{Colors.END}")
        results = {}

        # CPU cores
        cpu_cores = psutil.cpu_count(logical=False)
        cpu_logical = psutil.cpu_count(logical=True)
        required_cores = self.requirements["cpu_cores"]

        if cpu_cores >= required_cores:
            print(
                f"  {Colors.GREEN}✓{Colors.END} CPU: {cpu_cores} cores (physical), {cpu_logical} threads"
            )
            results["cpu"] = {
                "status": "pass",
                "actual": cpu_cores,
                "required": required_cores,
            }
        else:
            print(
                f"  {Colors.RED}✗{Colors.END} CPU: {cpu_cores} cores < {required_cores} required"
            )
            results["cpu"] = {
                "status": "fail",
                "actual": cpu_cores,
                "required": required_cores,
            }

        # RAM
        ram_gb = psutil.virtual_memory().total / (1024**3)
        required_ram = self.requirements["ram_gb"]

        if ram_gb >= required_ram:
            print(f"  {Colors.GREEN}✓{Colors.END} RAM: {ram_gb:.1f} GB available")
            results["ram"] = {
                "status": "pass",
                "actual": ram_gb,
                "required": required_ram,
            }
        else:
            print(
                f"  {Colors.RED}✗{Colors.END} RAM: {ram_gb:.1f} GB < {required_ram} GB required"
            )
            results["ram"] = {
                "status": "fail",
                "actual": ram_gb,
                "required": required_ram,
            }

        # Storage
        disk_usage = psutil.disk_usage("/")
        storage_gb = disk_usage.free / (1024**3)
        required_storage = self.requirements["storage_gb"]

        if storage_gb >= required_storage:
            print(
                f"  {Colors.GREEN}✓{Colors.END} Storage: {storage_gb:.1f} GB available"
            )
            results["storage"] = {
                "status": "pass",
                "actual": storage_gb,
                "required": required_storage,
            }
        else:
            print(
                f"  {Colors.RED}✗{Colors.END} Storage: {storage_gb:.1f} GB < {required_storage} GB required"
            )
            results["storage"] = {
                "status": "fail",
                "actual": storage_gb,
                "required": required_storage,
            }

        return results

    def check_software_dependencies(self) -> Dict:
        """Check required software dependencies"""
        print(f"\n{Colors.BOLD}📦 Software Dependencies{Colors.END}")
        results = {}

        dependencies = {
            "python": {
                "command": ["python3", "--version"],
                "version_pattern": r"Python (\d+\.\d+)",
                "required": self.requirements["python_version"],
            },
            "git": {
                "command": ["git", "--version"],
                "version_pattern": r"git version (\d+\.\d+)",
                "required": "2.30",
            },
            "make": {
                "command": ["make", "--version"],
                "version_pattern": r"GNU Make (\d+\.\d+)",
                "required": "4.2",
            },
        }

        for tool, config in dependencies.items():
            try:
                result = subprocess.run(
                    config["command"], capture_output=True, text=True, timeout=10
                )

                if result.returncode == 0:
                    import re

                    match = re.search(config["version_pattern"], result.stdout)
                    if match:
                        version = match.group(1)
                        if self._compare_versions(version, config["required"]) >= 0:
                            print(f"  {Colors.GREEN}✓{Colors.END} {tool}: v{version}")
                            results[tool] = {"status": "pass", "version": version}
                        else:
                            print(
                                f"  {Colors.YELLOW}⚠{Colors.END} {tool}: v{version} < v{config['required']} required"
                            )
                            results[tool] = {"status": "warn", "version": version}
                    else:
                        print(
                            f"  {Colors.YELLOW}⚠{Colors.END} {tool}: installed but version unknown"
                        )
                        results[tool] = {"status": "warn", "version": "unknown"}
                else:
                    print(f"  {Colors.RED}✗{Colors.END} {tool}: command failed")
                    results[tool] = {"status": "fail", "version": None}

            except subprocess.TimeoutExpired:
                print(f"  {Colors.RED}✗{Colors.END} {tool}: command timeout")
                results[tool] = {"status": "fail", "version": None}
            except FileNotFoundError:
                print(f"  {Colors.RED}✗{Colors.END} {tool}: not found")
                results[tool] = {"status": "fail", "version": None}

        return results

    def check_kubernetes_cluster(self) -> Dict:
        """Check Kubernetes cluster connectivity and resources, set up if missing"""
        print(f"\n{Colors.BOLD}☸️  Kubernetes Cluster{Colors.END}")
        results = {}

        try:
            # Check cluster connectivity
            result = subprocess.run(
                ["kubectl", "cluster-info"], capture_output=True, text=True, timeout=15
            )

            if result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} Cluster connectivity: OK")
                results["connectivity"] = {"status": "pass"}

                # Check node resources
                node_result = subprocess.run(
                    ["kubectl", "top", "nodes"],
                    capture_output=True,
                    text=True,
                    timeout=10,
                )

                if node_result.returncode == 0:
                    print(f"  {Colors.GREEN}✓{Colors.END} Node metrics: Available")
                    results["metrics"] = {"status": "pass"}
                else:
                    # Try once more after a short delay (metrics-server might be starting)
                    import time
                    time.sleep(3)
                    retry_result = subprocess.run(
                        ["kubectl", "top", "nodes"],
                        capture_output=True,
                        text=True,
                        timeout=10,
                    )
                    
                    if retry_result.returncode == 0:
                        print(f"  {Colors.GREEN}✓{Colors.END} Node metrics: Available")
                        results["metrics"] = {"status": "pass"}
                    else:
                        print(
                            f"  {Colors.YELLOW}⚠{Colors.END} Node metrics: Unavailable (metrics-server required)"
                        )
                        results["metrics"] = {"status": "warn"}

                # Check storage classes
                sc_result = subprocess.run(
                    ["kubectl", "get", "storageclass"],
                    capture_output=True,
                    text=True,
                    timeout=10,
                )

                if sc_result.returncode == 0 and "default" in sc_result.stdout:
                    print(
                        f"  {Colors.GREEN}✓{Colors.END} Storage classes: Default available"
                    )
                    results["storage_class"] = {"status": "pass"}
                else:
                    print(
                        f"  {Colors.YELLOW}⚠{Colors.END} Storage classes: No default storage class"
                    )
                    results["storage_class"] = {"status": "warn"}

            else:
                print(f"  {Colors.RED}✗{Colors.END} Cluster connectivity: Failed")
                print(f"  {Colors.BLUE}ℹ{Colors.END} Attempting to set up Kubernetes cluster with Minikube...")
                
                if self.setup_minikube_cluster():
                    # Retry connectivity check after setup
                    retry_result = subprocess.run(
                        ["kubectl", "cluster-info"], capture_output=True, text=True, timeout=15
                    )
                    if retry_result.returncode == 0:
                        print(f"  {Colors.GREEN}✓{Colors.END} Cluster connectivity: OK (after setup)")
                        results["connectivity"] = {"status": "pass"}
                    else:
                        print(f"  {Colors.RED}✗{Colors.END} Cluster setup failed")
                        results["connectivity"] = {"status": "fail"}
                else:
                    results["connectivity"] = {"status": "fail"}

        except subprocess.TimeoutExpired:
            print(f"  {Colors.RED}✗{Colors.END} Cluster connectivity: Timeout")
            results["connectivity"] = {"status": "fail"}
        except FileNotFoundError:
            print(f"  {Colors.RED}✗{Colors.END} kubectl not found")
            results["connectivity"] = {"status": "fail"}

        return results

    def setup_minikube_cluster(self) -> bool:
        """Set up a Minikube Kubernetes cluster for development"""
        print(f"  {Colors.BLUE}🔧 Setting up Minikube cluster...{Colors.END}")
        
        # Check if minikube is installed
        if not self.check_and_install_minikube():
            return False
        
        # Check if minikube cluster already exists but stopped
        status_result = subprocess.run(
            ["minikube", "status"], capture_output=True, text=True
        )
        
        if "Stopped" in status_result.stdout or status_result.returncode != 0:
            print(f"  {Colors.BLUE}🚀 Starting Minikube cluster...{Colors.END}")
            
            # Check if we're running as root and use appropriate driver
            import os
            if os.geteuid() == 0:
                print(f"  {Colors.YELLOW}⚠{Colors.END} Running as root, installing required packages...")
                
                # Install required packages for none driver including crictl
                install_packages = [
                    "apt", "update",
                    "&&", "apt", "install", "-y", 
                    "conntrack", "socat", "ebtables", "ethtool", "curl"
                ]
                
                pkg_result = subprocess.run(
                    " ".join(install_packages),
                    shell=True,
                    capture_output=True,
                    text=True,
                    timeout=120
                )
                
                if pkg_result.returncode == 0:
                    print(f"  {Colors.GREEN}✓{Colors.END} Required packages installed")
                else:
                    print(f"  {Colors.YELLOW}⚠{Colors.END} Package installation may have failed, continuing...")
                
                # Install crictl and attempt cri-dockerd for newer Kubernetes
                crictl_ok = self.install_crictl()
                cri_dockerd_ok = self.install_cri_dockerd()
                
                if crictl_ok and cri_dockerd_ok:
                    print(f"  {Colors.GREEN}✓{Colors.END} All required components installed")
                    start_command = [
                        "minikube", "start", 
                        "--driver=none"
                    ]
                else:
                    print(f"  {Colors.YELLOW}⚠{Colors.END} Some components failed, using default Kubernetes version...")
                    start_command = [
                        "minikube", "start", 
                        "--driver=none",
                        "--container-runtime=docker"
                    ]
            else:
                start_command = [
                    "minikube", "start", 
                    "--driver=docker",
                    "--memory=4096", 
                    "--cpus=2"
                ]
            
            start_result = subprocess.run(
                start_command,
                capture_output=True,
                text=True,
                timeout=300  # 5 minutes timeout
            )
            
            if start_result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} Minikube cluster started successfully")
                
                # Enable ingress addon for future use
                subprocess.run(
                    ["minikube", "addons", "enable", "ingress"],
                    capture_output=True,
                    text=True
                )
                
                # Enable metrics-server for monitoring
                subprocess.run(
                    ["minikube", "addons", "enable", "metrics-server"],
                    capture_output=True,
                    text=True
                )
                
                print(f"  {Colors.GREEN}✓{Colors.END} Essential addons enabled (ingress, metrics-server)")
                return True
            else:
                print(f"  {Colors.RED}✗{Colors.END} Failed to start Minikube")
                
                # Show specific error guidance
                error_msg = start_result.stderr.lower()
                if "crictl" in error_msg:
                    print(f"  {Colors.BLUE}💡{Colors.END} crictl is required for this Kubernetes version")
                    print(f"     Alternative: Use older Kubernetes version or run as non-root user")
                elif "docker" in error_msg:
                    print(f"  {Colors.BLUE}💡{Colors.END} Docker driver issue - ensure Docker is running")
                    print(f"     Try: sudo systemctl start docker")
                elif "permission" in error_msg or "access" in error_msg:
                    print(f"  {Colors.BLUE}💡{Colors.END} Permission issue detected")
                    print(f"     Try running as non-root user or check Docker group membership")
                
                print(f"  {Colors.YELLOW}⚠{Colors.END} Error details: {start_result.stderr.strip()}")
                
                # Try KIND as fallback
                print(f"  {Colors.BLUE}💡{Colors.END} Trying KIND (Kubernetes in Docker) as alternative...")
                if self.setup_kind_cluster():
                    return True
                
                return False
        else:
            print(f"  {Colors.GREEN}✓{Colors.END} Minikube cluster is already running")
            return True

    def check_and_install_minikube(self) -> bool:
        """Check if minikube is installed, install if missing"""
        try:
            result = subprocess.run(
                ["minikube", "version"], capture_output=True, text=True, timeout=10
            )
            
            if result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} Minikube is already installed")
                return True
        except FileNotFoundError:
            pass
        
        print(f"  {Colors.BLUE}📦 Installing Minikube...{Colors.END}")
        
        # Download and install minikube
        commands = [
            ["curl", "-LO", "https://storage.googleapis.com/minikube/releases/latest/minikube-linux-amd64"],
            ["sudo", "install", "minikube-linux-amd64", "/usr/local/bin/minikube"],
            ["rm", "minikube-linux-amd64"]
        ]
        
        for cmd in commands:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            if result.returncode != 0:
                print(f"  {Colors.RED}✗{Colors.END} Failed to install Minikube: {result.stderr}")
                return False
        
        print(f"  {Colors.GREEN}✓{Colors.END} Minikube installed successfully")
        return True

    def install_crictl(self) -> bool:
        """Install crictl (CRI CLI) required for Kubernetes 1.28.0+ in root environments"""
        try:
            # Check if crictl is already installed
            result = subprocess.run(
                ["crictl", "--version"], capture_output=True, text=True, timeout=5
            )
            if result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} crictl is already installed")
                return True
        except FileNotFoundError:
            pass
        
        print(f"  {Colors.BLUE}📦 Installing crictl...{Colors.END}")
        
        # Download and install crictl (using latest stable version)
        commands = [
            ["curl", "-L", "https://github.com/kubernetes-sigs/cri-tools/releases/download/v1.30.0/crictl-v1.30.0-linux-amd64.tar.gz", "-o", "crictl.tar.gz"],
            ["tar", "zxvf", "crictl.tar.gz"],
            ["mv", "crictl", "/usr/local/bin/"],
            ["rm", "crictl.tar.gz"]
        ]
        
        for cmd in commands:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            if result.returncode != 0:
                print(f"  {Colors.RED}✗{Colors.END} Failed to install crictl: {result.stderr}")
                return False
        
        print(f"  {Colors.GREEN}✓{Colors.END} crictl installed successfully")
        return True

    def install_cri_dockerd(self) -> bool:
        """Install cri-dockerd (CRI shim for Docker) required for Kubernetes 1.24+ with none driver"""
        try:
            # Check if cri-dockerd is already installed
            result = subprocess.run(
                ["cri-dockerd", "--version"], capture_output=True, text=True, timeout=5
            )
            if result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} cri-dockerd is already installed")
                return True
        except FileNotFoundError:
            pass
        
        print(f"  {Colors.BLUE}📦 Installing cri-dockerd...{Colors.END}")
        
        # Install dependencies first
        deps_cmd = ["apt", "update", "&&", "apt", "install", "-y", "curl", "wget", "systemd"]
        deps_result = subprocess.run(
            " ".join(deps_cmd),
            shell=True,
            capture_output=True,
            text=True,
            timeout=60
        )
        
        if deps_result.returncode != 0:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Failed to install dependencies, continuing...")
        
        # Download and install cri-dockerd
        commands = [
            ["wget", "https://github.com/Mirantis/cri-dockerd/releases/download/v0.3.4/cri-dockerd_0.3.4.3-0.ubuntu-jammy_amd64.deb", "-O", "cri-dockerd.deb"],
            ["dpkg", "-i", "cri-dockerd.deb"],
            ["systemctl", "enable", "cri-docker.service"],
            ["systemctl", "enable", "cri-docker.socket"],
            ["systemctl", "start", "cri-docker.service"],
            ["systemctl", "start", "cri-docker.socket"],
            ["rm", "cri-dockerd.deb"]
        ]
        
        for cmd in commands:
            result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
            if result.returncode != 0 and "systemctl" not in cmd[0]:
                print(f"  {Colors.RED}✗{Colors.END} Failed to install cri-dockerd: {result.stderr}")
                return False
        
        print(f"  {Colors.GREEN}✓{Colors.END} cri-dockerd installed successfully")
        return True

    def setup_kind_cluster(self) -> bool:
        """Set up a KIND (Kubernetes in Docker) cluster as alternative to Minikube"""
        print(f"  {Colors.BLUE}🔧 Setting up KIND cluster as alternative...{Colors.END}")
        
        # Check if kind is installed
        try:
            result = subprocess.run(["kind", "--version"], capture_output=True, text=True, timeout=5)
            if result.returncode != 0:
                raise FileNotFoundError
        except FileNotFoundError:
            print(f"  {Colors.BLUE}📦 Installing KIND...{Colors.END}")
            
            # Install KIND
            install_commands = [
                ["curl", "-Lo", "./kind", "https://kind.sigs.k8s.io/dl/v0.20.0/kind-linux-amd64"],
                ["chmod", "+x", "./kind"],
                ["mv", "./kind", "/usr/local/bin/kind"]
            ]
            
            for cmd in install_commands:
                result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
                if result.returncode != 0:
                    print(f"  {Colors.RED}✗{Colors.END} Failed to install KIND: {result.stderr}")
                    return False
            
            print(f"  {Colors.GREEN}✓{Colors.END} KIND installed successfully")
        
        # Check if cluster already exists
        cluster_result = subprocess.run(
            ["kind", "get", "clusters"], capture_output=True, text=True, timeout=10
        )
        
        if "kind" in cluster_result.stdout:
            print(f"  {Colors.GREEN}✓{Colors.END} KIND cluster already exists")
            return True
        
        # Create KIND cluster
        print(f"  {Colors.BLUE}🚀 Creating KIND cluster...{Colors.END}")
        create_result = subprocess.run(
            ["kind", "create", "cluster", "--name", "kind"],
            capture_output=True,
            text=True,
            timeout=300
        )
        
        if create_result.returncode == 0:
            print(f"  {Colors.GREEN}✓{Colors.END} KIND cluster created successfully")
            
            # Set kubectl context to kind
            context_result = subprocess.run(
                ["kubectl", "cluster-info", "--context", "kind-kind"],
                capture_output=True,
                text=True,
                timeout=10
            )
            
            if context_result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} kubectl configured for KIND cluster")
                
                # Install metrics-server for monitoring
                if self.install_metrics_server():
                    print(f"  {Colors.GREEN}✓{Colors.END} Cluster monitoring configured")
                else:
                    print(f"  {Colors.YELLOW}⚠{Colors.END} Cluster created but monitoring setup incomplete")
                
                return True
            else:
                print(f"  {Colors.YELLOW}⚠{Colors.END} KIND cluster created but kubectl config may need manual setup")
                return True
        else:
            print(f"  {Colors.RED}✗{Colors.END} Failed to create KIND cluster: {create_result.stderr}")
            return False

    def install_metrics_server(self) -> bool:
        """Install metrics-server for Kubernetes cluster monitoring"""
        print(f"  {Colors.BLUE}📊 Installing metrics-server...{Colors.END}")
        
        try:
            # Check if metrics-server is already installed
            check_result = subprocess.run(
                ["kubectl", "get", "deployment", "metrics-server", "-n", "kube-system"],
                capture_output=True,
                text=True,
                timeout=10
            )
            
            if check_result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} metrics-server is already installed")
                return True
                
        except subprocess.TimeoutExpired:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Timeout checking metrics-server status")
        
        # Install metrics-server using kubectl apply
        install_result = subprocess.run(
            ["kubectl", "apply", "-f", "https://github.com/kubernetes-sigs/metrics-server/releases/latest/download/components.yaml"],
            capture_output=True,
            text=True,
            timeout=60
        )
        
        if install_result.returncode != 0:
            print(f"  {Colors.RED}✗{Colors.END} Failed to install metrics-server: {install_result.stderr}")
            return False
        
        # Patch metrics-server for KIND/development environments (disable TLS verification)
        patch_result = subprocess.run([
            "kubectl", "patch", "deployment", "metrics-server", "-n", "kube-system",
            "--type", "json",
            "-p", '[{"op": "add", "path": "/spec/template/spec/containers/0/args/-", "value": "--kubelet-insecure-tls"}]'
        ], capture_output=True, text=True, timeout=30)
        
        if patch_result.returncode != 0:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Failed to patch metrics-server, but installation may still work")
        
        # Wait for metrics-server to be ready
        print(f"  {Colors.BLUE}⏳ Waiting for metrics-server to be ready...{Colors.END}")
        wait_result = subprocess.run([
            "kubectl", "wait", "--for=condition=available", "--timeout=60s",
            "deployment/metrics-server", "-n", "kube-system"
        ], capture_output=True, text=True, timeout=70)
        
        if wait_result.returncode == 0:
            print(f"  {Colors.GREEN}✓{Colors.END} metrics-server installed and ready")
            return True
        else:
            print(f"  {Colors.YELLOW}⚠{Colors.END} metrics-server installed but may need time to become ready")
            return True

    def check_helm_repositories(self) -> Dict:
        """Check Helm repositories, configure essential ones if missing"""
        print(f"\n{Colors.BOLD}📋 Helm Repositories{Colors.END}")
        results = {}

        try:
            result = subprocess.run(
                ["helm", "repo", "list"], capture_output=True, text=True, timeout=10
            )

            if result.returncode == 0 and result.stdout.strip():
                print(f"  {Colors.GREEN}✓{Colors.END} Helm repositories: Configured")
                results["repositories"] = {"status": "pass"}
                
                # Check for essential repositories
                repos_output = result.stdout
                essential_repos = {
                    "bitnami": "https://charts.bitnami.com/bitnami",
                    "stable": "https://charts.helm.sh/stable"
                }
                
                missing_repos = []
                for repo_name, repo_url in essential_repos.items():
                    if repo_name not in repos_output:
                        missing_repos.append((repo_name, repo_url))
                
                if missing_repos:
                    print(f"  {Colors.YELLOW}⚠{Colors.END} Adding missing essential repositories...")
                    for repo_name, repo_url in missing_repos:
                        self.add_helm_repository(repo_name, repo_url)
                    
                    # Update repository information
                    update_result = subprocess.run(
                        ["helm", "repo", "update"], capture_output=True, text=True, timeout=30
                    )
                    if update_result.returncode == 0:
                        print(f"  {Colors.GREEN}✓{Colors.END} Repository information updated")
                
            else:
                print(f"  {Colors.YELLOW}⚠{Colors.END} Helm repositories: None configured")
                print(f"  {Colors.BLUE}🔧 Configuring essential Helm repositories...{Colors.END}")
                
                if self.setup_essential_helm_repositories():
                    results["repositories"] = {"status": "pass"}
                else:
                    results["repositories"] = {"status": "warn"}

        except subprocess.TimeoutExpired:
            print(f"  {Colors.RED}✗{Colors.END} Helm repositories: Timeout")
            results["repositories"] = {"status": "fail"}
        except FileNotFoundError:
            print(f"  {Colors.RED}✗{Colors.END} helm not found")
            results["repositories"] = {"status": "fail"}

        return results

    def setup_essential_helm_repositories(self) -> bool:
        """Set up essential Helm repositories for NOAH deployment"""
        essential_repos = {
            "bitnami": "https://charts.bitnami.com/bitnami",
            "stable": "https://charts.helm.sh/stable",
            "prometheus-community": "https://prometheus-community.github.io/helm-charts",
            "grafana": "https://grafana.github.io/helm-charts",
            "ingress-nginx": "https://kubernetes.github.io/ingress-nginx"
        }
        
        success_count = 0
        for repo_name, repo_url in essential_repos.items():
            if self.add_helm_repository(repo_name, repo_url):
                success_count += 1
        
        if success_count > 0:
            # Update repository information
            print(f"  {Colors.BLUE}📡 Updating repository information...{Colors.END}")
            update_result = subprocess.run(
                ["helm", "repo", "update"], capture_output=True, text=True, timeout=60
            )
            
            if update_result.returncode == 0:
                print(f"  {Colors.GREEN}✓{Colors.END} {success_count} essential repositories configured")
                return True
            else:
                print(f"  {Colors.YELLOW}⚠{Colors.END} Repository update failed, but repositories added")
                return True
        
        return False

    def add_helm_repository(self, name: str, url: str) -> bool:
        """Add a single Helm repository"""
        try:
            result = subprocess.run(
                ["helm", "repo", "add", name, url],
                capture_output=True,
                text=True,
                timeout=30
            )
            
            if result.returncode == 0:
                print(f"    {Colors.GREEN}✓{Colors.END} Added repository: {name}")
                return True
            else:
                print(f"    {Colors.YELLOW}⚠{Colors.END} Failed to add {name}: {result.stderr.strip()}")
                return False
                
        except subprocess.TimeoutExpired:
            print(f"    {Colors.RED}✗{Colors.END} Timeout adding repository: {name}")
            return False

    def setup_kubernetes_environment(self) -> None:
        """Set up complete Kubernetes environment with Minikube and Helm repositories"""
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print("🚀 NOAH Kubernetes Environment Setup")
        print("=" * 50)
        print(f"{Colors.END}")
        
        print(f"{Colors.BOLD}Setting up Kubernetes development environment...{Colors.END}")
        print()
        
        # Step 1: Ensure system tools are available
        print(f"{Colors.BOLD}Step 1: Checking system tools{Colors.END}")
        print(f"💡 Use 'python3 script/noah-deps-manager --check-system-tools' if tools are missing")
        
        tools_check = {
            "docker": ["docker", "--version"],
            "kubectl": ["kubectl", "version", "--client"],
            "helm": ["helm", "version", "--short"]
        }
        tools_available = True
        
        for tool_name, command in tools_check.items():
            try:
                result = subprocess.run(command, capture_output=True, text=True, timeout=5)
                if result.returncode == 0:
                    print(f"  {Colors.GREEN}✓{Colors.END} {tool_name} is available")
                else:
                    print(f"  {Colors.RED}✗{Colors.END} {tool_name} is not working properly")
                    print(f"    Return code: {result.returncode}")
                    if result.stderr.strip():
                        print(f"    Error: {result.stderr.strip()}")
                    tools_available = False
            except FileNotFoundError:
                print(f"  {Colors.RED}✗{Colors.END} {tool_name} is not installed")
                tools_available = False
            except subprocess.TimeoutExpired:
                print(f"  {Colors.RED}✗{Colors.END} {tool_name} command timeout")
                tools_available = False
        
        if not tools_available:
            print(f"\n{Colors.RED}❌ Required tools are missing. Please run:{Colors.END}")
            print(f"   python3 script/noah-deps-manager --check-system-tools")
            return
        
        print()
        
        # Step 2: Set up Minikube cluster
        print(f"{Colors.BOLD}Step 2: Setting up Kubernetes cluster{Colors.END}")
        cluster_setup_success = False
        
        try:
            if self.setup_minikube_cluster():
                print(f"  {Colors.GREEN}✓{Colors.END} Kubernetes cluster is ready")
                cluster_setup_success = True
            else:
                print(f"  {Colors.YELLOW}⚠{Colors.END} Kubernetes cluster setup failed")
                print(f"  {Colors.BLUE}💡{Colors.END} Manual setup options:")
                print(f"     • Non-root setup: su - username && minikube start --driver=docker")
                print(f"     • Alternative: Use cloud Kubernetes (EKS, GKE, AKS)")
                print(f"     • For testing: Use kind (Kubernetes in Docker)")
                print(f"     • Continue anyway: Helm repositories will still be configured")
        except Exception as e:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Kubernetes cluster setup failed: {e}")
            print(f"  {Colors.BLUE}💡{Colors.END} Continuing with Helm setup...")
        
        print()
        
        # Step 3: Configure Helm repositories
        print(f"{Colors.BOLD}Step 3: Configuring Helm repositories{Colors.END}")
        if self.setup_essential_helm_repositories():
            print(f"  {Colors.GREEN}✓{Colors.END} Helm repositories are configured")
        else:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Some Helm repositories may not be configured")
        
        print()
        
        # Step 4: Verify the setup
        print(f"{Colors.BOLD}Step 4: Verifying setup{Colors.END}")
        
        # Test kubectl only if cluster setup was successful
        if cluster_setup_success:
            try:
                result = subprocess.run(["kubectl", "get", "nodes"], capture_output=True, text=True, timeout=10)
                if result.returncode == 0:
                    print(f"  {Colors.GREEN}✓{Colors.END} kubectl can access the cluster")
                    node_count = len([line for line in result.stdout.split('\n') if 'Ready' in line])
                    print(f"    📊 {node_count} node(s) ready")
                else:
                    print(f"  {Colors.RED}✗{Colors.END} kubectl cannot access the cluster")
            except subprocess.TimeoutExpired:
                print(f"  {Colors.RED}✗{Colors.END} kubectl access timeout")
        else:
            print(f"  {Colors.YELLOW}⚠{Colors.END} Skipping kubectl test (cluster not available)")
        
        # Test helm
        try:
            result = subprocess.run(["helm", "repo", "list"], capture_output=True, text=True, timeout=10)
            if result.returncode == 0:
                repo_count = len(result.stdout.strip().split('\n')) - 1  # Exclude header
                if repo_count > 0:
                    print(f"  {Colors.GREEN}✓{Colors.END} Helm has {repo_count} repositories configured")
                else:
                    print(f"  {Colors.YELLOW}⚠{Colors.END} Helm has no repositories configured")
            else:
                print(f"  {Colors.YELLOW}⚠{Colors.END} Helm repositories need configuration")
        except subprocess.TimeoutExpired:
            print(f"  {Colors.RED}✗{Colors.END} Helm check timeout")
        
        print()
        
        if cluster_setup_success:
            print(f"{Colors.GREEN}{Colors.BOLD}🎉 Kubernetes environment setup complete!{Colors.END}")
        else:
            print(f"{Colors.YELLOW}{Colors.BOLD}⚠️ Partial setup complete (Helm configured, Kubernetes cluster needs manual setup){Colors.END}")
            
        print()
        print(f"{Colors.BOLD}Next steps:{Colors.END}")
        
        if cluster_setup_success:
            print(f"  • Run full validation: python3 script/noah-tech-requirements")
            print(f"  • Deploy NOAH: ./noah deploy --profile minimal")
            print(f"  • Access cluster: minikube dashboard")
        else:
            print(f"  • Set up Kubernetes cluster manually (as non-root user):")
            print(f"    - Switch to non-root user: su - username")
            print(f"    - Run: minikube start --driver=docker")
            print(f"  • Or use a cloud Kubernetes service")
            print(f"  • Then run: python3 script/noah-tech-requirements")
            
        print()
        print(f"{Colors.BLUE}💡 Useful commands:{Colors.END}")
        print(f"  • minikube status          # Check cluster status")
        print(f"  • minikube stop           # Stop the cluster")
        print(f"  • minikube delete         # Delete the cluster")
        print(f"  • kubectl get pods -A     # List all pods")
        print(f"  • helm list -A            # List all Helm releases")

    def _compare_versions(self, version1: str, version2: str) -> int:
        """Compare semantic versions"""

        def normalize(v):
            return [int(x) for x in v.split(".")]

        v1 = normalize(version1)
        v2 = normalize(version2)

        # Pad with zeros to make equal length
        max_len = max(len(v1), len(v2))
        v1 += [0] * (max_len - len(v1))
        v2 += [0] * (max_len - len(v2))

        for i in range(max_len):
            if v1[i] > v2[i]:
                return 1
            elif v1[i] < v2[i]:
                return -1
        return 0

    def generate_report(self, results: Dict) -> None:
        """Generate summary report"""
        print(f"\n{Colors.BOLD}📊 VALIDATION SUMMARY{Colors.END}")
        print("=" * 60)

        total_checks = 0
        passed_checks = 0

        for category, checks in results.items():
            print(f"\n{Colors.BOLD}{category.title()}:{Colors.END}")

            for check_name, check_result in checks.items():
                total_checks += 1
                status = check_result["status"]

                if status == "pass":
                    print(f"  {Colors.GREEN}✓{Colors.END} {check_name}")
                    passed_checks += 1
                elif status == "warn":
                    print(f"  {Colors.YELLOW}⚠{Colors.END} {check_name}")
                    passed_checks += 0.5
                else:
                    print(f"  {Colors.RED}✗{Colors.END} {check_name}")

        print(f"\n{Colors.BOLD}Results:{Colors.END}")
        print(f"  Total checks: {total_checks}")
        print(f"  Passed: {int(passed_checks)}")
        print(f"  Warnings: {int((passed_checks % 1) * 2)}")
        print(
            f"  Failed: {total_checks - int(passed_checks) - int((passed_checks % 1) * 2)}"
        )

        if passed_checks == total_checks:
            print(
                f"\n{Colors.GREEN}🎉 All requirements satisfied for {self.profile} profile!{Colors.END}"
            )
        elif passed_checks >= total_checks * 0.8:
            print(
                f"\n{Colors.YELLOW}⚠ Most requirements satisfied. Review warnings above.{Colors.END}"
            )
        else:
            print(
                f"\n{Colors.RED}❌ Critical requirements not met. Address failures above.{Colors.END}"
            )

    def quick_verify(self) -> None:
        """Quick verification of basic requirements without full system check"""
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print("🔍 NOAH Quick Requirements Verification")
        print("=" * 40)
        print(f"{Colors.END}")

        # Check basic software availability
        tools = {
            "python3": "Python 3",
            "git": "Git Version Control",
            "make": "GNU Make"
        }

        all_present = True
        
        for tool, description in tools.items():
            try:
                result = subprocess.run(
                    [tool, "--version"], 
                    capture_output=True, 
                    text=True, 
                    timeout=5
                )
                
                if result.returncode == 0:
                    # Extract version info
                    version_info = result.stdout.split('\n')[0]
                    print(f"  {Colors.GREEN}✅ {description}:{Colors.END} {version_info}")
                else:
                    print(f"  {Colors.RED}❌ {description}:{Colors.END} Command failed")
                    all_present = False
                    
            except subprocess.TimeoutExpired:
                print(f"  {Colors.RED}❌ {description}:{Colors.END} Command timeout")
                all_present = False
            except FileNotFoundError:
                print(f"  {Colors.RED}❌ {description}:{Colors.END} Not installed")
                all_present = False

        # Summary
        print(f"\n{Colors.BOLD}Quick Verification Summary:{Colors.END}")
        if all_present:
            print(f"  {Colors.GREEN}🎉 All essential tools are available!{Colors.END}")
            print(f"  💡 Run with --full for comprehensive system validation")
        else:
            print(f"  {Colors.RED}⚠ Some tools are missing or not accessible{Colors.END}")
            print(f"  💡 Use noah-deps-manager --check-system-tools for Docker/kubectl/Helm installation")

    def show_troubleshooting_help(self) -> None:
        """Show troubleshooting guidance for common issues"""
        print(f"{Colors.CYAN}{Colors.BOLD}")
        print("🔧 NOAH Troubleshooting Guide")
        print("=" * 50)
        print(f"{Colors.END}")

        print(f"{Colors.BOLD}Common Issues and Solutions:{Colors.END}")
        print()

        print(f"{Colors.RED}❌ System tools (Docker/kubectl/Helm) missing{Colors.END}")
        print("   Solution: Use the dependency manager to install them")
        print("   python3 script/noah-deps-manager --check-system-tools")
        print()

        print(f"{Colors.RED}❌ kubectl: connection refused{Colors.END}")
        print("   Solution: Ensure Kubernetes cluster is running")
        print("   minikube status")
        print("   minikube start  # if stopped")
        print()

        print(f"{Colors.RED}❌ helm: repository not found{Colors.END}")
        print("   Solution: Add and update repositories")
        print("   helm repo add stable https://charts.helm.sh/stable")
        print("   helm repo update")
        print()

        print(f"{Colors.RED}❌ System resources insufficient{Colors.END}")
        print("   Solution: Check available resources")
        print("   free -h  # Check RAM")
        print("   df -h    # Check disk space")
        print("   nproc    # Check CPU cores")
        print()

        print(f"{Colors.YELLOW}⚠ For persistent issues:{Colors.END}")
        print("   1. Check system logs: journalctl -xe")
        print("   2. Verify network connectivity")
        print("   3. Check firewall settings")
        print("   4. Restart services: sudo systemctl restart docker")
        print()

        print(f"{Colors.BLUE}💡 Get detailed validation report:{Colors.END}")
        print("   python3 script/noah-tech-requirements --profile minimal --verbose")

    def validate_all(self) -> Dict:
        """Run all validation checks"""
        self.print_banner()

        results = {}

        # System resources
        results["system"] = self.check_system_resources()

        # Software dependencies
        results["software"] = self.check_software_dependencies()

        # Kubernetes cluster
        results["kubernetes"] = self.check_kubernetes_cluster()

        # Helm repositories
        results["helm"] = self.check_helm_repositories()

        # Generate report
        self.generate_report(results)

        return results


def main():
    """Main function"""
    import argparse

    parser = argparse.ArgumentParser(
        description="NOAH Technical Requirements Validator",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog="""
Examples:
  %(prog)s                        # Full validation with minimal profile
  %(prog)s --profile root         # Full validation with root profile
  %(prog)s --quick                # Quick verification of basic tools
  %(prog)s --troubleshoot         # Show troubleshooting guide
  %(prog)s --setup-k8s            # Set up Kubernetes cluster and Helm repositories
        """
    )
    parser.add_argument(
        "--profile",
        choices=["minimal", "root"],
        default="minimal",
        help="Deployment profile to validate against (default: minimal)",
    )
    parser.add_argument(
        "--quick",
        action="store_true",
        help="Quick verification of basic requirements without full system check",
    )
    parser.add_argument(
        "--troubleshoot",
        action="store_true",
        help="Show troubleshooting guidance for common issues",
    )
    parser.add_argument(
        "--setup-k8s",
        action="store_true",
        help="Automatically set up Kubernetes cluster (Minikube) and Helm repositories if missing",
    )
    parser.add_argument(
        "--full",
        action="store_true",
        help="Run full comprehensive validation (default behavior)",
    )

    args = parser.parse_args()

    validator = TechnicalRequirementsValidator(profile=args.profile)

    # Handle different modes
    if args.troubleshoot:
        validator.show_troubleshooting_help()
        return

    if args.setup_k8s:
        validator.setup_kubernetes_environment()
        return

    if args.quick:
        validator.quick_verify()
        return

    # Default: Full validation
    results = validator.validate_all()

    # Exit with appropriate code
    total_checks = sum(len(checks) for checks in results.values())
    passed_checks = sum(
        1
        for checks in results.values()
        for check in checks.values()
        if check["status"] == "pass"
    )

    if passed_checks == total_checks:
        sys.exit(0)
    elif passed_checks >= total_checks * 0.8:
        sys.exit(1)
    else:
        sys.exit(2)


if __name__ == "__main__":
    main()
